// ─── Doctor Selection ─────────────────────────────────────────────────────────
app.post('/appt-select-doctor', (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase().trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);

  if (!speech) {
    const g = gather(twiml, '/appt-select-doctor', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, pick(RETRY_PROMPTS) + ' Would you like to schedule with Dr. Eldred Taylor or Dr. Ava Bell-Taylor?');
    return res.type('text/xml').send(twiml.toString());
  }

  // Escape hatch
  const esc = checkEscape(speech, sess);
  if (esc.action === 'exit') {
    say(twiml, "Of course! Have a wonderful day!");
    twiml.hangup();
    return res.type('text/xml').send(twiml.toString());
  }
  if (esc.action === 'pivot') {
    twiml.redirect('/main-intent');
    return res.type('text/xml').send(twiml.toString());
  }

  // Detect doctor choice — Ava check MUST run first and be broad
  // Covers: "Ava", "Bell", "Ava Taylor", "Dr. Ava", "Dr. Bell", "Dr. Ava Taylor", "Dr. Ava Bell-Taylor"
  const isAva = /\bava\b|\bbell\b|ava\s+taylor|bell.?taylor|dr\.?\s*ava|dr\.?\s*bell/.test(speech);
  // Eldred check: only fires when there is NO Ava signal
  // Covers: "Eldred", "Dr. Eldred", "Dr. Taylor" (when no Ava keyword present), plain "Taylor"
  const isEldred = !isAva && /\beldred\b|dr\.?\s*eldred|\btaylor\b|dr\.?\s*taylor/.test(speech);

  let practitioner;
  if (isAva) {
    practitioner = CONFIG.intakeq.practitioners.ava;
  } else if (isEldred) {
    practitioner = CONFIG.intakeq.practitioners.eldred;
  } else if (/\bfirst\b|\bone\b|\b1\b/.test(speech)) {
    practitioner = CONFIG.intakeq.practitioners.eldred;
  } else if (/\bsecond\b|\btwo\b|\b2\b/.test(speech)) {
    practitioner = CONFIG.intakeq.practitioners.ava;
  } else {
    // Can't determine — ask again
    const g = gather(twiml, '/appt-select-doctor', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, "I just want to make sure I have that right — would you like to see Dr. Eldred Taylor or Dr. Ava Bell-Taylor?");
    return res.type('text/xml').send(twiml.toString());
  }

  sess.practitionerId = practitioner.id;
  sess.practitionerName = practitioner.name;
  say(twiml, `${pick(AFFIRMATIONS)} I'll get you scheduled with ${practitioner.name}.`);

  // Proceed to name collection or DOB if name already known
  if (sess.firstName && sess.lastName) {
    const g = gather(twiml, '/appt-collect-dob', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, `For verification, ${sess.pronouncedName || sess.firstName}, what is your date of birth?`);
  } else {
    const g = gather(twiml, '/appt-collect-name', { input: 'speech', speechTimeout: '2', timeout: 10 });
    say(g, 'Could you please tell me your first and last name?');
  }
  res.type('text/xml').send(twiml.toString());
});

app.post('/appt-collect-name', (req, res) => {
  const speech = (req.body.SpeechResult || '').trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  if (!speech || speech.length < 2) {
    const g = gather(twiml, '/appt-collect-name', { input: 'speech', speechTimeout: '2', timeout: 10 });
    say(g, pick(RETRY_PROMPTS) + ' Could you please tell me your first and last name?');
    return res.type('text/xml').send(twiml.toString());
  }
  // Escape hatch — let caller redirect or correct
  const esc = checkEscape(speech, sess);
  if (esc.action === 'exit') {
    say(twiml, "Of course! Have a wonderful day — don't hesitate to call us if you need anything!");
    twiml.hangup();
    return res.type('text/xml').send(twiml.toString());
  }
  if (esc.action === 'pivot') {
    twiml.redirect('/main-intent');
    return res.type('text/xml').send(twiml.toString());
  }
  sess.spokenName = speech;
  const g = gather(twiml, '/appt-spell-name', { input: 'speech', speechTimeout: '3', timeout: 15 });
  say(g, pick(AFFIRMATIONS) + ' To make sure I have your name exactly right, could you please spell your first name for me, one letter at a time?');
  res.type('text/xml').send(twiml.toString());
});

app.post('/appt-spell-name', (req, res) => {
  const speech = (req.body.SpeechResult || '').trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  if (!speech) {
    const g = gather(twiml, '/appt-spell-name', { input: 'speech', speechTimeout: '3', timeout: 15 });
    say(g, pick(RETRY_PROMPTS) + ' Could you please spell your first name, one letter at a time?');
    return res.type('text/xml').send(twiml.toString());
  }
  // Escape hatch
  const esc = checkEscape(speech, sess, { noPivot: true });
  if (esc.action === 'correct') {
    const g = gather(twiml, '/appt-collect-name', { input: 'speech', speechTimeout: '2', timeout: 10 });
    say(g, "No problem! Let's start over — what is your first and last name?");
    return res.type('text/xml').send(twiml.toString());
  }
  if (esc.action === 'exit') {
    say(twiml, "Of course! Have a wonderful day — don't hesitate to call us if you need anything!");
    twiml.hangup();
    return res.type('text/xml').send(twiml.toString());
  }
  if (esc.action === 'pivot') {
    twiml.redirect('/main-intent');
    return res.type('text/xml').send(twiml.toString());
  }
  const parsedFirst = normalizeName(speech);
  const cleanFirst = parsedFirst.includes(' ') ? parsedFirst.split(' ')[0] : parsedFirst;
  sess._pendingFirstName = cleanFirst;
  const g = gather(twiml, '/appt-confirm-firstname', { input: 'speech', speechTimeout: '3', timeout: 12 });
  say(g, `I have your first name as ${cleanFirst} — is that correct?`);
  res.type('text/xml').send(twiml.toString());
});

app.post('/appt-confirm-firstname', (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase().trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  const confirmed = /yes|correct|right|good|that.?s right|yep|yeah|uh.?huh|sounds good/.test(speech);
  if (!confirmed) {
    const g = gather(twiml, '/appt-spell-name', { input: 'speech', speechTimeout: '3', timeout: 15 });
    say(g, "No problem! Let me get your first name again — could you spell it for me, one letter at a time?");
