// ═══════════════════════════════════════════════════════════════════════════════
// ROUTE — Recording proxy (streams Twilio MP3 without requiring Twilio login)
// ═══════════════════════════════════════════════════════════════════════════════
app.get('/recording/:sid', async (req, res) => {
  const sid = req.params.sid;
  if (!sid || !sid.startsWith('RE')) return res.status(400).send('Invalid recording SID');
  try {
    const accountSid = CONFIG.twilio.accountSid;
    const authToken = CONFIG.twilio.authToken;
    const url = `https://api.twilio.com/2010-04-01/Accounts/${accountSid}/Recordings/${sid}.mp3`;
    const response = await axios({
      method: 'GET', url,
      auth: { username: accountSid, password: authToken },
      responseType: 'stream',
      maxRedirects: 5
    });
    res.setHeader('Content-Type', 'audio/mpeg');
    res.setHeader('Content-Disposition', `inline; filename="voicemail-${sid}.mp3"`);
    response.data.pipe(res);
  } catch (err) {
    console.error('[Recording proxy error]', err.message);
    res.status(404).send('Recording not found or expired');
  }
});
app.get('/health', (req, res) => res.json({ status: 'healthy', uptime: process.uptime() }));

// ── /call-logs — Recent calls to Taylor's number ──────────────────────────────
// GET https://tmg-ai-receptionist-production.up.railway.app/call-logs
app.get('/call-logs', async (req, res) => {
  try {
    const client = getTwilioClient();
    if (!client) return res.status(500).json({ error: 'Twilio client not initialized' });
    const limit = parseInt(req.query.limit) || 20;
    const calls = await client.calls.list({ to: CONFIG.twilio.phoneNumber, limit });
    const formatted = calls.map(c => ({
      callSid: c.sid,
      from: c.from,
      status: c.status,
      direction: c.direction,
      startTime: c.startTime,
      endTime: c.endTime,
      duration: c.duration ? `${c.duration}s` : 'in progress',
      recordingUrl: c.sid ? `https://tmg-ai-receptionist-production.up.railway.app/recording/${c.sid}` : null
    }));
    res.json({ total: formatted.length, calls: formatted });
  } catch (err) {
    console.error('[CALL-LOGS]', err.message);
    res.status(500).json({ error: err.message });
  }
});

