      <tr><td style="padding:6px;font-weight:bold;background:#f5f5f5">Caller Name / Company</td><td style="padding:6px">${sess.salesName || 'Not provided'}</td></tr>
      <tr><td style="padding:6px;font-weight:bold;background:#f5f5f5">Product / Service</td><td style="padding:6px">${sess.salesService || 'Not provided'}</td></tr>
