  const resendKey = CONFIG.email.resendApiKey;
  if (!resendKey) return false;
  const displayName = patientName || 'Valued Patient';
  const htmlBody = `
    <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 24px;">
      <h2 style="color: #2c5282;">Taylor Medical Group — Patient Portal</h2>
      <p>Hello ${displayName},</p>
      <p>Here is your direct link to the Taylor Medical Group Patient Portal:</p>
      <p style="text-align: center; margin: 24px 0;">
        <a href="https://www.taylormedicalgroup.net" style="background: #2c5282; color: white; padding: 14px 28px; border-radius: 6px; text-decoration: none; font-size: 16px; font-weight: bold;">
          Visit Patient Portal
        </a>
      </p>
      <p>Go to <strong>taylormedicalgroup.net</strong> and click <strong>Patient Portal</strong> in the top right corner to log in and message our team directly.</p>
      <p>If you have any questions, you can also reach us at <strong>678-443-4000</strong>.</p>
      <p style="color: #718096; font-size: 12px; margin-top: 24px;">Taylor Medical Group &mdash; 5901 Peachtree Dunwoody Rd, Bldg C, Suite C25, Sandy Springs, GA 30328</p>
    </div>
  `;
  const textBody = `Taylor Medical Group — Patient Portal\n\nHello ${displayName},\n\nHere is your patient portal link:\nhttps://www.taylormedicalgroup.net\n\nClick Patient Portal in the top right corner to log in and message our team.\n\nQuestions? Call 678-443-4000`;
  try {
    const response = await axios.post(
      'https://api.resend.com/emails',
      {
        from: CONFIG.email.fromAddress,
        to: [toEmail],
        subject: 'Taylor Medical Group — Your Patient Portal Link',
        html: htmlBody,
        text: textBody,
      },
      {
        headers: { 'Authorization': `Bearer ${resendKey}`, 'Content-Type': 'application/json' },
        timeout: 10000,
      }
    );
    console.log('[PORTAL EMAIL] Sent to', toEmail, ':', response.data?.id);
    return true;
  } catch (err) {
    console.error('[PORTAL EMAIL] Failed:', err.response?.data || err.message);
    return false;
  }
}

// ─── Staff notification helpers ───────────────────────────────────────────────
async function sendCallSummaryToStaff(callerPhone, summary, callSid = null, transcriptHtml = '') {
  const now = new Date().toLocaleString('en-US', { timeZone: 'America/New_York' });

  // Append recording link if available
  let recordingLine = '';
  let recordingHtml = '';
  if (callSid) {
    const sess = getSession(callSid);
    if (sess && sess.recordingSid) {
      const playbackUrl = `https://tmg-ai-receptionist-production.up.railway.app/recording/${sess.recordingSid}`;
      recordingLine = `\n🎙️ Recording: ${playbackUrl}`;
      recordingHtml = `
        <div style="background:#ebf8ff; border:1px solid #bee3f8; border-radius:8px; padding:16px; margin:16px 0;">
          <p style="margin:0 0 10px 0; font-size:15px; font-weight:bold; color:#2b6cb0;">🎙️ Call Recording</p>
          <p style="margin:0 0 12px 0; font-size:13px; color:#4a5568;">Click the button below to listen to this call. No login required.</p>
          <a href="${playbackUrl}"
             style="display:inline-block; background:#2b6cb0; color:#ffffff; text-decoration:none;
                    padding:10px 22px; border-radius:6px; font-size:14px; font-weight:bold;">
            ▶️ Play Recording
          </a>
          <p style="margin:12px 0 0 0; font-size:11px; color:#718096; word-break:break-all;">
            Direct link: <a href="${playbackUrl}" style="color:#2b6cb0;">${playbackUrl}</a>
          </p>
        </div>
      `;
    }
  }

  const msg = `📋 TMG Call Summary — ${now} ET\n📱 Caller: ${callerPhone}\n─────────────────────\n${summary}${recordingLine}`;

  // SMS (may be blocked by A2P issue — email is primary)
  for (const num of CONFIG.escalation.smsNumbers) await sendSms(num, msg).catch(() => {});

  // Email summary
  const htmlBody = `
    <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
      <h2 style="color: #2c5282; border-bottom: 2px solid #2c5282; padding-bottom: 8px;">
        📋 TMG Call Summary
      </h2>
      <p><strong>Time:</strong> ${now} ET</p>
      <p><strong>Caller:</strong> ${callerPhone}</p>
      ${recordingHtml}
      <hr style="border: 1px solid #e2e8f0;" />
      <div style="background: #f7fafc; padding: 16px; border-radius: 8px; white-space: pre-wrap; font-size: 14px;">
        ${summary.replace(/\n/g, '<br>')}
      </div>
      ${transcriptHtml}
      <p style="color: #718096; font-size: 12px; margin-top: 16px;">
        Sent by Taylor AI Receptionist — Taylor Medical Group
      </p>
    </div>
  `;
  await sendEmail(
    `TMG Call Summary — ${now} ET | Caller: ${callerPhone}`,
    htmlBody,
    msg
  ).catch(() => {});
}

