  const speech = (req.body.SpeechResult || '').trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  sess.newPharmacyFax = speech || 'not provided';
  sess.pendingPharmacyBlock = `Name: ${sess.newPharmacyName}\nAddress: ${sess.newPharmacyAddress}\nPhone: ${sess.newPharmacyPhone}\nFax: ${sess.newPharmacyFax}`;
  // If patient already identified this call, skip PIN and go straight to refill-verified
  if (sess.refillVerified || (sess.patientRecord && sess.patientRecord.ClientId)) {
    say(twiml, `Thank you — I have your pharmacy information on file.`);
    twiml.redirect('/refill-verified');
  } else {
    say(twiml, `Thank you — I have your pharmacy information. Now I just need to verify your identity.`);
    twiml.redirect('/refill-check-pin');
  }
  res.type('text/xml').send(twiml.toString());
});

app.post('/refill-check-pin', async (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase().trim();
  const digits = (req.body.Digits || '').trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  const providedPin = digits || speech.replace(/\D/g, '');
  const noPin = /no|don.t have|nope|none/.test(speech) || (!digits && !providedPin);

  try {
    const timeoutPromise = new Promise((_, reject) => setTimeout(() => reject(new Error('Patient lookup timed out')), 12000));
    const client = await Promise.race([findPatientByNameAndDob(sess.refillFirstName, sess.refillLastName, sess.refillDob, sess.collectedPhone || sess.callerPhone), timeoutPromise]);
    if (!client) {
      const patientEmail = sess.patientRecord?.Email || null;
      if (patientEmail) sendPortalLinkToPatient(patientEmail, `${sess.refillFirstName || ''} ${sess.refillLastName || ''}`.trim()).catch(() => {});
      sendCallSummaryToStaff(sess.callerPhone, `Reason: Refill — patient not found\nName: ${sess.refillFirstName} ${sess.refillLastName} | DOB: ${sess.refillDob}`).catch(() => {});
      say(twiml, "I wasn't able to find your record with that information. I've sent the patient portal link to your email on file. Please visit Taylor Medical Group dot net and click Patient Portal in the top right corner — you can message our team directly there and they will assist you.");
      const g = gather(twiml, '/main-intent', { input: 'speech', speechTimeout: '2', timeout: 10 });
      say(g, 'Is there anything else I can help you with today?');
      twiml.hangup();
      return res.type('text/xml').send(twiml.toString());
    }
    sess.refillClientId = client.ClientId || client.Id;
    sess.refillClientNumber = client.ClientNumber;
    sess.refillClientName = client.Name;
    sess.refillClientPhone = client.Phone;
    sess.refillClientEmail = client.Email;
    const storedPin = extractPin(client.AdditionalInformation);

    if (!noPin && providedPin && storedPin && providedPin === storedPin) {
      sess.refillVerified = true;
      twiml.redirect('/refill-verified');
    } else if (!noPin && providedPin && storedPin && providedPin !== storedPin) {
      const refillEmail = client?.Email || null;
      if (refillEmail) sendPortalLinkToPatient(refillEmail, sess.refillClientName || '').catch(() => {});
      sendCallSummaryToStaff(sess.callerPhone, `Reason: Refill — PIN mismatch\nPatient: ${sess.refillClientName}`).catch(() => {});
      say(twiml, "I'm sorry, that PIN doesn't match what we have on file. For your security, I've sent the patient portal link to your email on file. Please visit Taylor Medical Group dot net and click Patient Portal in the top right corner to message our team directly.");
      const gRefillMismatch = gather(twiml, '/main-intent', { input: 'speech', speechTimeout: '2', timeout: 10 });
      say(gRefillMismatch, 'Is there anything else I can help you with today?');
      twiml.hangup();
    } else {
      // No PIN or no PIN on file — create one
      const newPin = generatePin();
      sess.pendingPin = newPin;
      await storePinForClient(sess.refillClientId, newPin, client.AdditionalInformation);
      say(twiml, `I've created a security PIN for you and I'm sending it to you by both text and email right now. Please save it — you'll use it for all future calls to verify your identity. Once you receive it, please tell me the PIN to continue.`);
      const smsTarget = sess.callerPhone;
      await sendSms(smsTarget, `Taylor Medical Group — Your Security PIN\n\nYour PIN is: ${newPin}\n\nPlease save this for future calls to verify your identity.\n\nPatient portal: ${CONFIG.intakeq.portalUrl}`);
      const g = gather(twiml, '/refill-pin-verify', { input: 'speech dtmf', speechTimeout: '2', timeout: 30 });
      say(g, "Go ahead and say or enter your PIN whenever you're ready.");
    }
  } catch (err) {
    console.error('[REFILL PIN CHECK]', err.message);
    const refillErrEmail = sess.patientRecord?.Email || null;
    if (refillErrEmail) sendPortalLinkToPatient(refillErrEmail, `${sess.refillFirstName || ''} ${sess.refillLastName || ''}`.trim()).catch(() => {});
    say(twiml, "I'm having a little trouble right now. I've sent the patient portal link to your email on file. Please visit Taylor Medical Group dot net and click Patient Portal in the top right corner to submit your prescription refill request directly.");
    const gRefillErr = gather(twiml, '/main-intent', { input: 'speech', speechTimeout: '2', timeout: 10 });
    say(gRefillErr, 'Is there anything else I can help you with today?');
    twiml.hangup();
  }
  res.type('text/xml').send(twiml.toString());
});

app.post('/refill-pin-verify', (req, res) => {
  const rawSpeech = (req.body.SpeechResult || '').toLowerCase().trim();
  const digits = (req.body.Digits || '').trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  const providedPin = digits || rawSpeech.replace(/\D/g, '');

  // Detect "can't receive / didn't get it" — send to portal
  const cantReceive = /can.t|cannot|didn.t|did not|don.t|do not|not get|not receive|never got|never received|no email|no pin|haven.t|not getting|not coming|won.t/.test(rawSpeech);
  if (cantReceive) {
    const refillEmail = sess.refillClientEmail || sess.patientRecord?.Email || null;
    if (refillEmail) sendPortalLinkToPatient(refillEmail, sess.refillClientName || '').catch(() => {});
    say(twiml, "No problem at all! I've just sent the patient portal link to your phone and email right now — please check your inbox and look for an email from us. You can also visit Taylor Medical Group dot net directly and click Patient Portal in the top right corner. Once you're in the portal, you can message our team directly for help with your prescription. Please note that we do not accept emails from patients — all requests must go through the patient portal.");
    const g = gather(twiml, '/main-intent', { input: 'speech', speechTimeout: '2', timeout: 10 });
    say(g, 'Is there anything else I can help you with today?');
    twiml.hangup();
    return res.type('text/xml').send(twiml.toString());
  }

  if (providedPin === sess.pendingPin) {
    sess.refillVerified = true;
    twiml.redirect('/refill-verified');
  } else {
    sess.refillPinAttempts = (sess.refillPinAttempts || 0) + 1;
    if (sess.refillPinAttempts >= 2) {
      const refillEmail = sess.refillClientEmail || sess.patientRecord?.Email || null;
      if (refillEmail) sendPortalLinkToPatient(refillEmail, sess.refillClientName || '').catch(() => {});
      say(twiml, "I'm sorry, that PIN doesn't match. I've sent the patient portal link to your email on file. Please visit Taylor Medical Group dot net and click Patient Portal in the top right corner to message our team for help with your prescription.");
      const g = gather(twiml, '/main-intent', { input: 'speech', speechTimeout: '2', timeout: 10 });
      say(g, 'Is there anything else I can help you with today?');
      twiml.hangup();
    } else {
      const g = gather(twiml, '/refill-pin-verify', { input: 'speech dtmf', speechTimeout: '2', timeout: 20 });
      say(g, "That PIN doesn't match. Please check your email and try again, or let me know if you didn't receive it.");
    }
  }
  res.type('text/xml').send(twiml.toString());
});

app.post('/refill-verified', async (req, res) => {
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  // Save pharmacy block to IntakeQ now that we have the confirmed clientId
  if (sess.pendingPharmacyBlock && sess.refillClientId) {
    try {
      // Pull current AdditionalInformation to preserve PIN
      const clientData = await intakeqRequest('GET', `/clients?clientId=${sess.refillClientId}`);
      const existingInfo = (Array.isArray(clientData) ? clientData[0] : clientData)?.AdditionalInformation || '';
      await storePharmacyForClient(sess.refillClientId, sess.pendingPharmacyBlock, existingInfo);
      console.log(`[PHARMACY] Saved for client ${sess.refillClientId}: ${sess.pendingPharmacyBlock.split('\n')[0]}`);
    } catch (err) {
      console.error('[PHARMACY SAVE]', err.message);
    }
    delete sess.pendingPharmacyBlock;
  }
  // Skip phone/address confirmation entirely if patient already went through booking or main patient flow this call
  // contactInfoConfirmed is set during the main booking/established patient flow
  if (sess.contactInfoConfirmed || sess.bookingComplete || (sess.patientRecord && sess.patientRecord.ClientId)) {
    // Already have their info — go straight to medication question
    twiml.redirect('/refill-ask-medication');
  } else {
    say(twiml, `Great, I've verified your identity and saved your pharmacy information — welcome back!`);
    const g = gather(twiml, '/refill-confirm-phone', { input: 'speech', speechTimeout: '3', timeout: 10 });
    say(g, `Let me confirm your contact information. The phone number we have on file ends in ${(sess.refillClientPhone || '').slice(-4) || 'unknown'}. Is that still correct? Just say yes or no.`);
  }
  res.type('text/xml').send(twiml.toString());
});

app.post('/refill-confirm-phone', (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase().trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  if (/no|wrong|changed|different|update/.test(speech)) {
    const g = gather(twiml, '/refill-update-phone', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, "No problem at all! What's your new phone number?");
  } else {
    const g = gather(twiml, '/refill-confirm-address', { input: 'speech', speechTimeout: '3', timeout: 10 });
    say(g, "And is your address still the same as what we have on file? Just say yes or no.");
  }
  res.type('text/xml').send(twiml.toString());
});

app.post('/refill-update-phone', async (req, res) => {
  const speech = (req.body.SpeechResult || '').trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  if (speech) {
    const newPhone = speech.replace(/\D/g, '');
    if (newPhone.length >= 10) await updatePatientContact(sess.refillClientId, { Phone: newPhone }).catch(() => {});
    say(twiml, `Got it — I've updated your phone number. `);
  }
  const g = gather(twiml, '/refill-confirm-address', { input: 'speech', speechTimeout: '3', timeout: 10 });
  say(g, "Is your address still the same as what we have on file? Just say yes or no.");
  res.type('text/xml').send(twiml.toString());
});

app.post('/refill-confirm-address', (req, res) => {
