// ═══════════════════════════════════════════════════════════════════════════════
// ROUTE — Prescription refill start
// ═══════════════════════════════════════════════════════════════════════════════
app.post('/refill-start', (req, res) => {
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  // If patient was already fully verified this call (existing patient flow), skip all re-collection and PIN
  if (sess.patientRecord && sess.patientRecord.ClientId) {
    sess.refillFirstName = sess.firstName || sess.patientRecord.FirstName || '';
    sess.refillLastName = sess.lastName || sess.patientRecord.LastName || '';
    sess.refillDob = sess.dob || '';
    sess.refillClientId = sess.patientRecord.ClientId || sess.patientRecord.Id;
    sess.refillClientNumber = sess.patientRecord.ClientNumber;
    sess.refillClientName = sess.patientRecord.Name;
    sess.refillClientPhone = sess.patientRecord.Phone;
    sess.refillClientEmail = sess.patientRecord.Email;
    sess.refillVerified = true;
    // Always collect pharmacy info first, even for verified patients
    twiml.redirect('/refill-collect-pharmacy-name');
  } else if (sess.firstName && sess.lastName && sess.dob) {
    // Identity collected this call but no full patient record — collect pharmacy then check PIN
    sess.refillFirstName = sess.firstName;
    sess.refillLastName = sess.lastName;
    sess.refillDob = sess.dob;
    twiml.redirect('/refill-collect-pharmacy-name');
  } else {
    const g = gather(twiml, '/refill-collect-name', { input: 'speech', speechTimeout: '2', timeout: 10 });
    say(g, "I'd be happy to help with your prescription refill! To pull up your chart, could you please tell me your first and last name?");
  }
  res.type('text/xml').send(twiml.toString());
});

app.post('/refill-collect-name', (req, res) => {
  const speech = (req.body.SpeechResult || '').trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  if (!speech) {
    const g = gather(twiml, '/refill-collect-name', { input: 'speech', speechTimeout: '2', timeout: 10 });
    say(g, "I didn't catch that. Could you please say your first and last name?");
    return res.type('text/xml').send(twiml.toString());
  }
  const normalizedFull = normalizeName(speech);
  const parts = normalizedFull.split(/\s+/);
  sess.refillFirstName = parts[0] || '';
  sess.refillLastName = parts.slice(1).join(' ') || '';
  const g = gather(twiml, '/refill-collect-dob', { input: 'speech', speechTimeout: '2', timeout: 10 });
  say(g, `Thank you! And could you please tell me your date of birth?`);
  res.type('text/xml').send(twiml.toString());
});

app.post('/refill-collect-dob', (req, res) => {
  const speech = (req.body.SpeechResult || '').trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  sess.refillDob = speech;
  // Collect pharmacy info BEFORE PIN verification
  twiml.redirect('/refill-collect-pharmacy-name');
  res.type('text/xml').send(twiml.toString());
});

// ─── Pharmacy collection (before PIN) ────────────────────────────────────────
function extractPharmacy(info) {
  const m = (info || '').match(/Pharmacy:[\s\S]*?(?=\n[A-Z]|$)/);
  return m ? m[0].replace('Pharmacy:', '').trim() : null;
}
async function storePharmacyForClient(clientId, pharmacyBlock, existingInfo) {
  let info = (existingInfo || '').replace(/Pharmacy:[\s\S]*?(?=\n[A-Z]|$)/m, '').trim();
  info = `Pharmacy:\n${pharmacyBlock}${info ? '\n' + info : ''}`;
  return await intakeqRequest('POST', '/clients', { ClientId: clientId, AdditionalInformation: info });
}

