app.post('/pharmacy-message', async (req, res) => {
  const speech = (req.body.SpeechResult || '').trim();
  const callSid = req.body.CallSid;
  const callerPhone = req.body.From || 'anonymous';
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  sess.rxAdditionalMessage = speech || 'none';

  // Look up patient in IntakeQ to check last appointment date
  let lastApptNote = '';
  let needsApptWarning = false;
  try {
    const nameParts = (sess.rxPatientName || '').trim().split(/\s+/);
    const pFirst = nameParts[0] || '';
    const pLast = nameParts.slice(1).join(' ') || '';
    const patient = await findPatientByNameAndDob(pFirst, pLast, sess.rxPatientDob || '', sess.rxPatientPhone || '');
    if (patient) {
      const clientId = patient.ClientNumber || patient.ClientId || patient.Id;
      const lastAppt = await getLastAppointmentDate(clientId);
      if (!lastAppt) {
        lastApptNote = 'No completed appointments found in IntakeQ.';
        needsApptWarning = true;
      } else {
        const monthsAgo = (Date.now() - lastAppt.getTime()) / (1000 * 60 * 60 * 24 * 30.44);
        const apptStr = lastAppt.toLocaleDateString('en-US', { timeZone: 'America/New_York', year: 'numeric', month: 'long', day: 'numeric' });
        if (monthsAgo > 6) {
          lastApptNote = `Last appointment: ${apptStr} (${Math.floor(monthsAgo)} months ago) — OVER 6 MONTHS. Patient may need to schedule an appointment or retest labs before refill can be processed.`;
          needsApptWarning = true;
        } else {
          lastApptNote = `Last appointment: ${apptStr} (${Math.floor(monthsAgo)} months ago) — within 6 months.`;
        }
      }
    } else {
      lastApptNote = 'Patient not found in IntakeQ by name/DOB. Please verify manually.';
      needsApptWarning = true;
    }
  } catch (e) {
    lastApptNote = 'Could not check appointment history (IntakeQ lookup error).';
  }

  const subject = `💊 Pharmacy Request — ${sess.rxPatientName || 'Unknown Patient'} — ${sess.rxName || 'Unknown Medication'}`;
  const htmlBody = `
    <div style="font-family:Arial,sans-serif;max-width:650px">
      <h2 style="color:#2c5282;">Pharmacy Prescription Request</h2>
      <h3 style="color:#4a5568;">Pharmacy Information</h3>
      <table style="border-collapse:collapse;width:100%">
        <tr><td style="padding:6px 12px;font-weight:bold;width:180px">Pharmacist / Pharmacy:</td><td style="padding:6px 12px">${sess.pharmacistName || 'not provided'}</td></tr>
        <tr style="background:#f7fafc"><td style="padding:6px 12px;font-weight:bold">Phone:</td><td style="padding:6px 12px">${sess.pharmacyPhone || 'not provided'}</td></tr>
        <tr><td style="padding:6px 12px;font-weight:bold">Fax:</td><td style="padding:6px 12px">${sess.pharmacyFax || 'not provided'}</td></tr>
        <tr style="background:#f7fafc"><td style="padding:6px 12px;font-weight:bold">Email:</td><td style="padding:6px 12px">${sess.pharmacyEmail || 'not provided'}</td></tr>
      </table>
      <h3 style="color:#4a5568;margin-top:20px">Patient Information</h3>
      <table style="border-collapse:collapse;width:100%">
        <tr><td style="padding:6px 12px;font-weight:bold;width:180px">Full Name:</td><td style="padding:6px 12px">${sess.rxPatientName || 'not provided'}</td></tr>
        <tr style="background:#f7fafc"><td style="padding:6px 12px;font-weight:bold">Date of Birth:</td><td style="padding:6px 12px">${sess.rxPatientDob || 'not provided'}</td></tr>
        <tr><td style="padding:6px 12px;font-weight:bold">Phone:</td><td style="padding:6px 12px">${sess.rxPatientPhone || 'not provided'}</td></tr>
        <tr style="background:#f7fafc"><td style="padding:6px 12px;font-weight:bold">Address:</td><td style="padding:6px 12px">${sess.rxPatientAddress || 'not provided'}</td></tr>
      </table>
      <h3 style="color:#4a5568;margin-top:20px">Prescription Details</h3>
      <table style="border-collapse:collapse;width:100%">
        <tr><td style="padding:6px 12px;font-weight:bold;width:180px">Medication:</td><td style="padding:6px 12px">${sess.rxName || 'not provided'}</td></tr>
        <tr style="background:#f7fafc"><td style="padding:6px 12px;font-weight:bold">Dosage:</td><td style="padding:6px 12px">${sess.rxDosage || 'not provided'}</td></tr>
        <tr><td style="padding:6px 12px;font-weight:bold">Instructions:</td><td style="padding:6px 12px">${sess.rxInstructions || 'not provided'}</td></tr>
        <tr style="background:#f7fafc"><td style="padding:6px 12px;font-weight:bold">Quantity:</td><td style="padding:6px 12px">${sess.rxQuantity || 'not provided'}</td></tr>
        <tr><td style="padding:6px 12px;font-weight:bold">Refills:</td><td style="padding:6px 12px">${sess.rxRefills || 'not provided'}</td></tr>
        <tr style="background:#f7fafc"><td style="padding:6px 12px;font-weight:bold">Additional Message:</td><td style="padding:6px 12px">${sess.rxAdditionalMessage || 'none'}</td></tr>
      </table>
      <h3 style="color:#4a5568;margin-top:20px">Appointment History</h3>
      <p style="${needsApptWarning ? 'color:#c53030;font-weight:bold' : 'color:#276749'}">${lastApptNote}</p>
      ${needsApptWarning ? '<p style="color:#c53030"><strong>⚠️ Action Required:</strong> Patient may need to schedule an appointment or retest labs before this refill can be processed. Please review and advise the pharmacy accordingly.</p>' : ''}
      <hr style="margin:20px 0">
      <p style="color:#718096;font-size:12px">Received via Taylor AI Receptionist — ${new Date().toLocaleString('en-US', { timeZone: 'America/New_York' })}</p>
    </div>`;
  const textBody = `PHARMACY REQUEST

Pharmacist/Pharmacy: ${sess.pharmacistName}
Pharmacy Phone: ${sess.pharmacyPhone}
Pharmacy Fax: ${sess.pharmacyFax}
Pharmacy Email: ${sess.pharmacyEmail}

Patient: ${sess.rxPatientName}
DOB: ${sess.rxPatientDob}
Phone: ${sess.rxPatientPhone}
Address: ${sess.rxPatientAddress}

Medication: ${sess.rxName}
Dosage: ${sess.rxDosage}
Instructions: ${sess.rxInstructions}
Quantity: ${sess.rxQuantity}
Refills: ${sess.rxRefills}
Additional Message: ${sess.rxAdditionalMessage}

Appointment History: ${lastApptNote}`;

  await sendEmail(subject, htmlBody, textBody).catch(() => {});
  sendCallSummaryToStaff(callerPhone, `Reason: Pharmacy prescription request\nPharmacy: ${sess.pharmacistName}\nPatient: ${sess.rxPatientName}\nMedication: ${sess.rxName}\nAppointment note: ${lastApptNote}\nOutcome: Staff emailed`).catch(() => {});

  // Inform pharmacy of preferred submission method and 6-month policy if applicable
  const warningScript = needsApptWarning
    ? ` Please note that our records indicate this patient may need to schedule an appointment or have their labs retested before we can process this refill, as it has been more than 6 months since their last visit. Our team will review and follow up with you directly.`
    : '';

  say(twiml, `Thank you so much for that information! I've sent a detailed message to our entire team right now and they will follow up with you as soon as possible.${warningScript} In the meantime, our preferred method is for you to fax your request to 6 7 8, 4 4 3, 4 0 9 0, or email us at info at taylormedicalgroup dot net. Is there anything else I can help you with today?`);
  const g = gather(twiml, '/main-intent', { input: 'speech', speechTimeout: '2', timeout: 10 });
  say(g, '');
  twiml.hangup();
  res.type('text/xml').send(twiml.toString());
});

app.use((err, req, res, next) => {
  console.error('[ERROR]', err);
  res.status(500).json({ error: 'Internal server error' });
});
