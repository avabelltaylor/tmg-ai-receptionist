// Step 3: Collect sex/gender
app.post('/appt-new-collect-sex', (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase().trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  if (/male|man|boy/.test(speech) && !/fe/.test(speech)) {
    sess.gender = 'Male';
  } else if (/female|woman|girl|fe/.test(speech)) {
    sess.gender = 'Female';
  } else if (/other|prefer not|non.?binary|nonbinary/.test(speech)) {
    sess.gender = 'Other';
  } else {
    // Didn't catch it — ask again
    const g = gather(twiml, '/appt-new-collect-sex', { input: 'speech', speechTimeout: '2', timeout: 10 });
    say(g, pick(RETRY_PROMPTS) + ' What is your biological sex — male or female?');
    return res.type('text/xml').send(twiml.toString());
  }
  // Proceed to emergency contact collection
  const g = gather(twiml, '/appt-new-collect-emergency-name', { input: 'speech', speechTimeout: '2', timeout: 15 });
  say(g, `${pick(AFFIRMATIONS)} And for your chart, I need an emergency contact. What is your emergency contact's full name?`);
  res.type('text/xml').send(twiml.toString());
});

