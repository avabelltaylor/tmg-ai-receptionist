app.post('/recording-status', (req, res) => {
  const { RecordingSid, RecordingUrl, RecordingStatus, CallSid, RecordingDuration } = req.body;
  console.log(`[RECORDING] CallSid=${CallSid} | RecordingSid=${RecordingSid} | Status=${RecordingStatus} | Duration=${RecordingDuration}s | URL=${RecordingUrl}`);
  // Store recording SID on the session so it can be included in call summaries
  const sess = getSession(CallSid);
  if (sess && RecordingSid) {
    sess.recordingSid = RecordingSid;
    sess.recordingUrl = RecordingUrl;
  }
  res.sendStatus(200);
});

// ─── IntakeQ helpers ─────────────────────────────────────────────────────────
async function intakeqRequest(method, path, data = null) {
  try {
    const response = await axios({
      method, url: `${CONFIG.intakeq.baseUrl}${path}`,
      headers: { 'X-Auth-Key': CONFIG.intakeq.apiKey, 'Content-Type': 'application/json' },
      data, timeout: 6000, // 6s per call — keeps total under Twilio's 15s webhook limit
    });
    return response.data;
  } catch (err) {
    console.error(`[IntakeQ] ${method} ${path}:`, err.response?.data || err.message);
    return null;
  }
}

// ─── Live IntakeQ pricing lookup ─────────────────────────────────────────────
let _cachedSettings = null;
let _settingsCachedAt = 0;
async function getIntakeQSettings() {
  const now = Date.now();
  if (_cachedSettings && (now - _settingsCachedAt) < 15 * 60 * 1000) return _cachedSettings;
  const data = await intakeqRequest('GET', '/appointments/settings');
  if (data && data.Services) {
    _cachedSettings = data;
    _settingsCachedAt = now;
  }
  return _cachedSettings;
}

async function findServicePrice(keywords) {
  const settings = await getIntakeQSettings();
  if (!settings || !settings.Services) return null;
  const kw = keywords.toLowerCase();
  // Score each service by how many keywords match its name
  const scored = settings.Services
    .filter(s => s.Price > 0)
    .map(s => {
      const name = (s.Name || '').toLowerCase();
      const words = kw.split(/\s+/);
      const score = words.filter(w => w.length > 2 && name.includes(w)).length;
      return { ...s, score };
    })
    .filter(s => s.score > 0)
    .sort((a, b) => b.score - a.score);
  return scored.length > 0 ? scored[0] : null;
}

async function findPatientByNameAndDob(firstName, lastName, dob, phone) {
  const normalize = s => (s || '').toLowerCase().replace(/[^a-z]/g, '');
  const fnNorm = normalize(firstName);
  const lnNorm = normalize(lastName);

  // Strategy 1: search by last name (most reliable in IntakeQ)
  let candidates = [];
  if (lastName && lastName.length > 1) {
    const r = await intakeqRequest('GET', `/clients?search=${encodeURIComponent(lastName.trim())}`);
    if (r && r.length > 0) candidates = r;
  }

  // Strategy 2: if no results by last name, try full name
  if (candidates.length === 0 && firstName && lastName) {
    const r = await intakeqRequest('GET', `/clients?search=${encodeURIComponent(firstName + ' ' + lastName)}`);
    if (r && r.length > 0) candidates = r;
  }

  // Strategy 3: if still nothing, try first name alone
  if (candidates.length === 0 && firstName && firstName.length > 1) {
    const r = await intakeqRequest('GET', `/clients?search=${encodeURIComponent(firstName.trim())}`);
    if (r && r.length > 0) candidates = r;
  }

  // Strategy 4: try phone number as fallback
  if (candidates.length === 0 && phone) {
    const cleanPhone = phone.replace(/\D/g, '').slice(-10);
    if (cleanPhone.length >= 7) {
      const r = await intakeqRequest('GET', `/clients?search=${encodeURIComponent(cleanPhone)}`);
      if (r && r.length > 0) candidates = r;
    }
  }

  if (candidates.length === 0) return null;

  // IntakeQ search API returns: { Name, Email, Phone, ClientNumber }
  // Filter: prefer records where Name field contains both first and last name
  const nameMatch = candidates.filter(c => {
    const fullName = normalize(c.Name || '');
    return fullName.includes(fnNorm) && fullName.includes(lnNorm);
  });
  let pool = nameMatch.length > 0 ? nameMatch : candidates;

  // If multiple records match the same name, disambiguate by phone number
  if (pool.length > 1 && phone) {
    const cleanPhone = phone.replace(/\D/g, '').slice(-10);
    const phoneMatch = pool.filter(c => {
      const cp = (c.Phone || '').replace(/\D/g, '').slice(-10);
      return cp && cp === cleanPhone;
    });
    if (phoneMatch.length > 0) pool = phoneMatch;
  }

  // Return best match (first in filtered pool)
  return pool[0];
}

function extractPin(additionalInfo) {
  if (!additionalInfo) return null;
  const m = additionalInfo.match(/SecurityPIN:(\d{4,6})/);
  return m ? m[1] : null;
}

async function storePinForClient(clientId, pin, existingInfo) {
  let info = (existingInfo || '').replace(/SecurityPIN:\d{4,6}/g, '').trim();
  info = `SecurityPIN:${pin}${info ? '\n' + info : ''}`;
  return await intakeqRequest('POST', '/clients', { ClientId: clientId, AdditionalInformation: info });
}

function generatePin() { return String(Math.floor(1000 + Math.random() * 9000)); }

// ─── Name normalization ───────────────────────────────────────────────────────
// Handles both spelled names ("j o h n s o n") and spoken names ("johnson")
// Returns properly title-cased name, e.g. "Johnson"
function normalizeName(raw) {
  if (!raw) return '';
  // Strip filler words and leading phrases
  let s = raw.toLowerCase()
    .replace(/\b(my name is|i am|this is|it.s|its|um|uh|hmm|like|so|well)\b/g, '')
    .replace(/[^a-z ]/g, '')
    .trim();
  const words = s.split(/\s+/).filter(Boolean);
  // If every word is a single letter, it's a spelled name — join them
  // Also handle partial groupings like "ld" or "re" from imperfect Twilio transcription
  // by treating any sequence of mostly-single-letter words as a spelled name
  const singleLetterCount = words.filter(w => w.length === 1).length;
  const isSpelled = words.length > 1 && (words.every(w => w.length === 1) || (singleLetterCount >= words.length * 0.6 && words.join('').length <= 20));
  if (isSpelled) {
    const joined = words.join('');
    return joined.charAt(0).toUpperCase() + joined.slice(1).toLowerCase();
  }
  // Otherwise title-case each word
  return words.map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
}

// ─── Speech variation — human-like response pools ────────────────────────────
// Pick a random item from an array so Taylor never sounds scripted
function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

const AFFIRMATIONS = [
  'Got it!', 'Perfect!', 'Absolutely!', 'Of course!', 'Great!',
  'Wonderful!', 'Sure thing!', 'No problem at all!', 'Sounds good!'
];
const EMPATHY = [
  "I completely understand, and I want to make sure we get this sorted out for you.",
  "I hear you — let me help you with that right away.",
  "I’m so sorry about that — let’s get this taken care of.",
  "Absolutely, I’m on it — let me take care of that for you."
];
const RETRY_PROMPTS = [
  "I’m sorry, I didn’t quite catch that — could you say that one more time?",
  "Sorry about that! Could you repeat that for me?",
  "I missed that — one more time, please?",
  "I didn’t get that clearly — could you try again?"
];
const HOLD_PHRASES = [
  "Just one moment while I pull that up for you!",
  "Give me just a second — I’m looking that up now.",
  "One moment please — let me check on that for you.",
  "Bear with me just a second!"
];

// ─── Parse spelled-out email from speech ─────────────────────────────────────
function parseSpelledEmail(speech) {
  if (!speech) return null;
  let s = speech.toLowerCase().trim();
  
  // Handle "at sign" → "@", "at" → "@"
  s = s.replace(/\bat sign\b/g, '@');
  s = s.replace(/\bat\b/g, '@');
  
  // Handle "dot com", "dot net", etc.
  s = s.replace(/\bdot com\b/g, '.com');
  s = s.replace(/\bdot net\b/g, '.net');
  s = s.replace(/\bdot org\b/g, '.org');
  s = s.replace(/\bdot edu\b/g, '.edu');
  s = s.replace(/\bdot gov\b/g, '.gov');
  s = s.replace(/\bdot io\b/g, '.io');
  s = s.replace(/\bdot co\b/g, '.co');
  
  // Handle "underscore" → "_", "dash" → "-"
  s = s.replace(/\bunderscore\b/g, '_');
  s = s.replace(/\bdash\b/g, '-');
  s = s.replace(/\bhyphen\b/g, '-');
  
  // Handle "dot" between words (not already converted) → "."
  s = s.replace(/\bdot\b/g, '.');
  
  // Remove spaces between letters (spelled out: "a b c" → "abc")
  // But preserve @ and . and _ and -
  // Strategy: split on @ to handle local and domain separately
  const parts = s.split('@');
  if (parts.length !== 2) return null;
  
  // Clean local part: remove spaces between single chars
  let local = parts[0].trim();
  local = local.replace(/([a-z0-9_\-\.]) ([a-z0-9_\-\.])/g, '$1$2');
  local = local.replace(/([a-z0-9_\-\.]) ([a-z0-9_\-\.])/g, '$1$2'); // run twice for odd-length
  local = local.replace(/\s+/g, ''); // remove any remaining spaces
  
  // Clean domain part
  let domain = parts[1].trim();
  domain = domain.replace(/([a-z0-9\.]) ([a-z0-9\.])/g, '$1$2');
  domain = domain.replace(/([a-z0-9\.]) ([a-z0-9\.])/g, '$1$2');
  domain = domain.replace(/\s+/g, '');
  
  // Validate basic email format
  const email = `${local}@${domain}`;
  if (!email.includes('.') || email.length < 5) return null;
  
  // Strip trailing dots
  return email.replace(/\.+$/, '');
}

// ─── Spell out email address for TTS readback ────────────────────────────────
// Converts "john@gmail.com" → "j. o. h. n. at sign. g. m. a. i. l. dot. c. o. m."
// Each character is separated by a period+space so TTS pauses between letters.
function spellOutEmail(email) {
  // Read email naturally: "ava underscore taylor at yahoo dot com"
  if (!email || !email.includes('@')) return email;
  const [local, domain] = email.split('@');
  // Format local part: replace _ with "underscore", . with "dot"
  const localSpoken = local
    .replace(/_/g, ' underscore ')
    .replace(/\./g, ' dot ')
    .replace(/\s+/g, ' ')
    .trim();
  // Format domain: replace . with "dot"
  const domainSpoken = domain
    .replace(/\./g, ' dot ')
    .replace(/\s+/g, ' ')
    .trim();
  return `${localSpoken} at ${domainSpoken}`;
}


// ─── Name pronunciation helper ────────────────────────────────────────────────
// Ensures names are properly title-cased for Polly Neural TTS
function toPronouncedName(name) {
  if (!name) return name;
  return name.split(' ')
    .map(w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase())
    .join(' ');
}

// ─── Context-aware escape hatch ───────────────────────────────────────────────
// Returns { action, intent } where action is 'continue' | 'correct' | 'pivot' | 'exit'
function checkEscape(speech, sess, opts = {}) {
  const s = (speech || '').toLowerCase();
  // Correction signals
  if (/that.s wrong|i made a mistake|wrong name|wrong number|wrong date|go back|start over|let me change|i need to correct|actually it.?s|no wait|wait no|i said wrong|i meant/.test(s)) {
    return { action: 'correct' };
  }
  // Exit signals
  if (/never mind|forget it|that.?s all|i.?m done|no thank you|no thanks|goodbye|bye|hang up/.test(s)) {
    return { action: 'exit' };
  }
  // Pivot to a different intent — DISABLED for data-entry routes (spelling, DOB, phone, address)
  // to prevent false positives when caller says a name/word that matches an intent keyword
  if (!opts.noPivot) {
    const pivotIntent = detectIntent(speech);
    const currentFlow = sess._currentFlow || '';
    const pivotFlows = { appointment: 'appointment', refill: 'refill', cancel: 'cancel', labs: 'labs', portal: 'portal', directions: 'directions', hours: 'hours', billing: 'billing', transfer: 'transfer' };
    if (pivotIntent && pivotIntent !== 'unknown' && pivotFlows[pivotIntent] && pivotIntent !== currentFlow) {
      return { action: 'pivot', intent: pivotIntent };
    }
  }
  return { action: 'continue' };
}

async function updatePatientContact(clientId, updates) {
  return await intakeqRequest('POST', '/clients', { ClientId: clientId, ...updates });
}

async function getLastAppointmentDate(clientId) {
  const appts = await intakeqRequest('GET', `/appointments?clientId=${clientId}&status=Completed`);
  if (!appts || !Array.isArray(appts) || appts.length === 0) return null;
  appts.sort((a, b) => b.StartDate - a.StartDate);
  return new Date(appts[0].StartDate);
}

async function findOrCreateClient(firstName, lastName, phone, dob, address) {
  const cleanPhone = phone.replace(/\D/g, '').slice(-10);
  // Search by phone first
  const results = await intakeqRequest('GET', `/clients?search=${encodeURIComponent(cleanPhone)}`);
  if (results && results.length > 0) {
    const c = results[0];
    const id = c.ClientId || c.Id || c.ClientNumber;
    if (id) return { id, isNew: false, client: c };
  }
  // Also try searching by name if phone not found
  const nameResults = await intakeqRequest('GET', `/clients?search=${encodeURIComponent(firstName + ' ' + lastName)}`);
  if (nameResults && nameResults.length > 0) {
    const c = nameResults[0];
    const id = c.ClientId || c.Id || c.ClientNumber;
    if (id) return { id, isNew: false, client: c };
  }
  // Create new client with all collected info
  const clientData = { FirstName: firstName, LastName: lastName, Phone: cleanPhone };
  if (dob) clientData.DateOfBirth = dob;
  if (address) clientData.Address = address;
  const newClient = await intakeqRequest('POST', '/clients', clientData);
  if (newClient && (newClient.ClientId || newClient.Id)) return { id: newClient.ClientId || newClient.Id, isNew: true, client: newClient };
  return { id: null, isNew: false, client: null };
}

function getEtOffsetMs(date) {
  const utcStr = date.toLocaleString('en-US', { timeZone: 'UTC' });
  const etStr = date.toLocaleString('en-US', { timeZone: 'America/New_York' });
  return new Date(utcStr).getTime() - new Date(etStr).getTime();
}

async function findOpenSlots(serviceId, daysAhead = 14) {
  const slots = [];
  const now = new Date();
  const endDate = new Date(now); endDate.setDate(endDate.getDate() + daysAhead);
  const startStr = now.toISOString().split('T')[0];
  const endStr = endDate.toISOString().split('T')[0];
  const existing = await intakeqRequest('GET', `/appointments?startDate=${startStr}&endDate=${endStr}&status=Confirmed&practitionerEmail=info@taylormedicalgroup.net`);
  const bookedTimes = new Set();
  if (existing && Array.isArray(existing)) for (const a of existing) if (a.Status !== 'Canceled') bookedTimes.add(a.StartDate);
  const patientDays = new Set([1, 2, 3, 4, 5]); // Mon-Fri
  for (let d = 1; d <= daysAhead && slots.length < 6; d++) {
    const candidate = new Date(now); candidate.setDate(candidate.getDate() + d);
    const etStr = candidate.toLocaleString('en-US', { timeZone: 'America/New_York' });
    const etDate = new Date(etStr);
    const dayOfWeek = etDate.getDay();
    if (!patientDays.has(dayOfWeek)) continue;
    const closingHour = dayOfWeek === 5 ? 15 : 17; // Fri closes at 3 PM ET
    for (let h = 10; h < closingHour && slots.length < 6; h++) {
      const slotEt = new Date(etDate); slotEt.setHours(h, 0, 0, 0);
      const slotUtcMs = slotEt.getTime() + getEtOffsetMs(slotEt);
      if (bookedTimes.has(slotUtcMs) || slotUtcMs <= now.getTime()) continue;
      const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
      const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
      const ampm = h < 12 ? 'AM' : 'PM';
      const dh = h <= 12 ? h : h - 12;
      slots.push({ label: `${days[dayOfWeek]}, ${months[slotEt.getMonth()]} ${slotEt.getDate()} at ${dh}:00 ${ampm}`, utcMs: slotUtcMs });
    }
  }
  return slots;
}

async function bookAppointment(clientId, serviceId, utcMs, practitionerId) {
  const pid = practitionerId || CONFIG.intakeq.practitionerId;
  return await intakeqRequest('POST', '/appointments', {
    PractitionerId: pid,
    ClientId: clientId, ServiceId: serviceId,
    LocationId: CONFIG.intakeq.locationId,
    Status: 'WaitingConfirmation',
    UtcDateTime: utcMs,
    SendClientEmailNotification: false,
    ReminderType: 'Sms',
  });
}

// ─── Sessions ────────────────────────────────────────────────────────────────
const sessions = {};
function getSession(callSid) { if (!sessions[callSid]) sessions[callSid] = {}; return sessions[callSid]; }
function clearSession(callSid) { delete sessions[callSid]; }

// ─── Intent detection ────────────────────────────────────────────────────────
function detectIntent(speech) {
  const s = speech.toLowerCase();
  if (/emergency|urgent|chest pain|bleeding|can.t breathe|heart attack|stroke|dying/.test(s)) return 'emergency';
  if (/cancel|reschedul/.test(s)) return 'cancel';
  if (/work excuse|disability form|fmla|work form|disability paper|hsa form|hsa document|\bletter\b|doctor.?s note|note for work|write.*letter|need.*letter|letter for|documentation request|medical letter|letter from.*doctor|letter from.*dr/.test(s)) return 'forms';
  if (/medical record|copy of my record|copy of my lab|records request/.test(s)) return 'records';
  if (/i.m calling about.*product|i.m a sales|i.m with.*company|i.m a rep|sales rep|sales call|i sell|we sell|i.m selling|i represent.*company|i.m a vendor|i.m from.*company|calling to offer|calling to introduce|calling about our (product|service|solution|software|platform|system)|business development|account executive|account manager|i.m reaching out about/.test(s)) return 'sales';
  if (/not a patient|not patient|sales|vendor|representative|business proposal|not calling as a patient/.test(s)) return 'nonpatient';
  if (/transfer|speak to|talk to|receptionist|front desk|live person|live agent|human|operator|winston|office manager/.test(s)) return 'transfer';
  if (/appoint|schedul|book|visit|come in|see the doctor|new patient|established|initial visit|first visit|evaluation|i.d like to come|i want to come|i need to come|i.d like to be seen|i want to be seen|i need to be seen|i.d like to schedule|i want to schedule|i need to schedule|make an appointment|set up an appointment|get an appointment|get in|get seen|get checked|get a visit|get a consultation|consultation|consult/.test(s)) return 'appointment';
  if (/calling from.*pharmacy|this is.*pharmacy|i.m.*pharmacist|calling on behalf of.*pharmacy|pharmacy calling|pharmacist calling/.test(s)) return 'pharmacy';
  if (/refill|prescription|rx|medication|medicine|pharmacy|drug/.test(s)) return 'refill';
  if (/lab|result|test result|blood work|hormone result/.test(s)) return 'labs';
  if (/portal|patient portal|log in|login|account/.test(s)) return 'portal';
  if (/direction|address|location|lost|find you|where are you|parking|suite|complex|building/.test(s)) return 'directions';
  if (/hour|open|close|when do you|what time|office hour|available/.test(s)) return 'hours';
  if (/telehealth|virtual|video visit|phone visit|zoom/.test(s)) return 'telehealth';
  if (/children|child|kid|pediatric|son|daughter|minor/.test(s)) return 'children';
  if (/iv|infusion|drip|chelat|glutathione|nad|ketamine|vitamin c|hydrogen peroxide|methylene blue|myers|hydration|magnesium|iron infusion|ozone iv/.test(s)) return 'iv';
  if (/service|treat|offer|hormone|weight|cosmetic|cancer|bhrt|testosterone|peptide|ozone|semaglutide|ozempic|tirzepatide|mounjaro|pcos|menopause|thyroid|adrenal|fibroid|erectile|sex drive|hot flash|night sweat|insomnia|fatigue|brain fog|hair loss|skin|acne|melasma|botox|filler|microneedling|liposuction|strawberry|prp|o.shot|p.shot|stem cell|exosome|autoimmune|diabetes|hypertension|lupus|lyme|parkinson|dementia|fibromyalgia|leaky gut|parasite|heavy metal|gadolinium|cancer support|arthritis|gout|migraine|headache|postpartum|depression|anxiety|add|attention|bladder|incontinence|vaginal|painful intercourse|skin lightening|skin discolor|melasma|psoriasis|eczema|hemochromatosis|fatty liver|metabolic|cholesterol|triglyceride|chronic fatigue|fibromyalgia|viral|pain|uti|urinary tract|insulin resistance|hypothyroid|low vitamin d|nutritional deficiency|inflammatory|leaky gut|parasite/.test(s)) return 'services';
  if (/bill|invoice|cost|price|how much|fee|charge|payment|insurance|hsa|fsa|affirm|financ|discount|package/.test(s)) return 'billing';
  if (/fax/.test(s)) return 'fax';
  if (/email/.test(s)) return 'email';
  if (/doctor|dr taylor|dr ava|speak with doctor|talk to doctor|call me back|call back/.test(s)) return 'transfer';
  if (/leave a message|leave message|voicemail|message for the doctor|message for the office/.test(s)) return 'voicemail';
  return 'unknown';
}

// ═══════════════════════════════════════════════════════════════════════════════
// ROUTE — Incoming call greeting
// ═══════════════════════════════════════════════════════════════════════════════
app.post('/voice', (req, res) => {
  const twiml = new VoiceResponse();
  const callSid = req.body.CallSid;
  const callerPhone = req.body.From || 'anonymous';
  const sess = getSession(callSid);
  sess.callerPhone = callerPhone;
  sess.callStartTime = new Date().toLocaleString('en-US', { timeZone: 'America/New_York' });
  sess.callLog = [];

  // Initialize transcript entry for this call
  transcriptStore[callSid] = { callSid, from: callerPhone, start: new Date().toISOString(), turns: [] };

  // ── Enable call recording for every inbound call via REST API (avoids TwiML validation issues) ──
  // We trigger the recording via Twilio REST API after call connects, not via TwiML <Record>
  // This is done asynchronously so it doesn't block the greeting
  const accountSid = process.env.TWILIO_ACCOUNT_SID;
  const authToken = process.env.TWILIO_AUTH_TOKEN;
  if (accountSid && authToken) {
    setTimeout(() => {
      const https = require('https');
      const postData = 'RecordingChannels=dual&RecordingStatusCallback=%2Frecording-status';
      const opts = {
        hostname: 'api.twilio.com',
        path: `/2010-04-01/Accounts/${accountSid}/Calls/${callSid}/Recordings.json`,
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
          'Content-Length': Buffer.byteLength(postData),
          'Authorization': 'Basic ' + Buffer.from(`${accountSid}:${authToken}`).toString('base64')
        }
      };
      const req2 = https.request(opts, r => {
        let body = '';
        r.on('data', d => body += d);
        r.on('end', () => console.log(`[RECORDING] Started for ${callSid}: ${r.statusCode}`));
      });
      req2.on('error', e => console.error(`[RECORDING] Error for ${callSid}:`, e.message));
      req2.write(postData);
      req2.end();
    }, 3000); // wait 3s for call to be fully connected before starting recording
  }

  // Universal intake gate — collect name before anything else
  const greeting = "Hi there! Thank you so much for calling Taylor Medical Group — this is Taylor, and I am so glad you called! May I start by getting your first and last name?";
  const g = gather(twiml, '/intake-firstname', { input: 'speech', speechTimeout: '2', timeout: 15 });
  say(g, greeting, callSid, '/voice');
  twiml.redirect('/voice');
  res.type('text/xml').send(twiml.toString());
});

// ═══════════════════════════════════════════════════════════════════════════════
// ROUTE — Universal intake: collect caller name
// ═══════════════════════════════════════════════════════════════════════════════
app.post('/intake-firstname', (req, res) => {
  const speech = (req.body.SpeechResult || '').trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  // Filter out filler phrases that are not names
  const FILLER_PHRASES = /^(hi|hello|hey|hi there|hello there|good morning|good afternoon|good evening|thank you|thanks|sure|okay|ok|yes|yeah|yep|uh huh|um|uh|hmm|oh|oh hi|oh hello|oh okay|oh sure)([\.\!\?\,]?\s*.*)?$/i;
  if (!speech || speech.length < 2 || FILLER_PHRASES.test(speech.trim())) {
    const g = gather(twiml, '/intake-firstname', { input: 'speech', speechTimeout: '2', timeout: 15 });
    say(g, "I'd love to help! Could you please tell me your first and last name?");
    return res.type('text/xml').send(twiml.toString());
  }
  // Store spoken name, then ask them to spell it for accuracy
  sess.spokenName = speech;
  const g = gather(twiml, '/intake-spell-name', { input: 'speech', speechTimeout: '3', timeout: 15 });
  say(g, "Thank you so much! Just to make sure I have your name exactly right, could you spell your first name for me, one letter at a time?");
  res.type('text/xml').send(twiml.toString());
});

app.post('/intake-spell-name', (req, res) => {
  const speech = (req.body.SpeechResult || '').trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  if (!speech || speech.length < 2) {
    const g = gather(twiml, '/intake-spell-name', { input: 'speech', speechTimeout: '3', timeout: 15 });
    say(g, pick(RETRY_PROMPTS) + " Could you spell your first name for me, one letter at a time?");
    return res.type('text/xml').send(twiml.toString());
  }
  const parsedFirst = normalizeName(speech);
  const cleanFirst = parsedFirst.includes(' ') ? parsedFirst.split(' ')[0] : parsedFirst;
  sess._pendingFirstName = cleanFirst;
  const g = gather(twiml, '/intake-confirm-firstname', { input: 'speech', speechTimeout: '3', timeout: 12 });
  say(g, `I have your first name as ${cleanFirst} — is that correct?`);
  res.type('text/xml').send(twiml.toString());
});

app.post('/intake-confirm-firstname', (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase().trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  const confirmed = /yes|correct|right|good|that.?s right|yep|yeah|uh.?huh/.test(speech);
  if (!confirmed) {
    // Check if caller is already providing the correction inline (e.g. "No, it's R-E-G-I-N-A")
    const correctionInline = /^(no|nope|wrong|incorrect|wait|actually|i meant|sorry|that.?s wrong|not quite|not right|let me correct)[,\s]+(.+)/i.exec(req.body.SpeechResult || '');
    if (correctionInline && correctionInline[2] && correctionInline[2].trim().length > 1) {
      // Caller already gave the correction — process it directly
      const parsedFirst = normalizeName(correctionInline[2].trim());
      const cleanFirst = parsedFirst.includes(' ') ? parsedFirst.split(' ')[0] : parsedFirst;
      sess._pendingFirstName = cleanFirst;
      const g = gather(twiml, '/intake-confirm-firstname', { input: 'speech', speechTimeout: '3', timeout: 12 });
      say(g, `Got it! I have your first name as ${cleanFirst} — is that correct?`);
      return res.type('text/xml').send(twiml.toString());
    }
    const g = gather(twiml, '/intake-spell-name', { input: 'speech', speechTimeout: '3', timeout: 15 });
    say(g, 'No problem! Go ahead and spell your first name for me, one letter at a time.');
    return res.type('text/xml').send(twiml.toString());
  }
  sess.firstName = sess._pendingFirstName;
  delete sess._pendingFirstName;
  const g = gather(twiml, '/intake-spell-lastname', { input: 'speech', speechTimeout: '3', timeout: 15 });
  say(g, `${pick(AFFIRMATIONS)} And could you spell your last name for me, one letter at a time?`);
  res.type('text/xml').send(twiml.toString());
});

