      <tr><td style="padding:6px;font-weight:bold;background:#f5f5f5">Phone</td><td style="padding:6px">${sess.salesPhone || 'Not provided'}</td></tr>
      <tr><td style="padding:6px;font-weight:bold;background:#f5f5f5">Caller Phone</td><td style="padding:6px">${sess.callerPhone || 'Unknown'}</td></tr>
      <tr><td style="padding:6px;font-weight:bold;background:#f5f5f5">Call Time</td><td style="padding:6px">${sess.callStartTime || new Date().toLocaleString('en-US', { timeZone: 'America/New_York' })}</td></tr>
    </table>
    <p style="margin-top:16px;color:#555">This inquiry was captured by Taylor AI. Review and follow up at your discretion.</p>
  `;
  const text = `Sales Inquiry\nCaller: ${sess.salesName}\nProduct/Service: ${sess.salesService}\nWebsite: ${sess.salesWebsite}\nPhone: ${sess.salesPhone}`;
  sendEmail(subject, html, text).catch(() => {});
  sendCallSummaryToStaff(sess.callerPhone, `Reason: Sales inquiry\nCaller: ${sess.salesName}\nProduct: ${sess.salesService}\nWebsite: ${sess.salesWebsite}\nPhone: ${sess.salesPhone}\nOutcome: Info captured, directed to email`).catch(() => {});
  say(twiml, `Thank you so much! I've passed your information along to our team. If they are interested in learning more, someone will be in touch. In the meantime, you're also welcome to email us directly at info at taylor medical group dot net — that's info at T-A-Y-L-O-R M-E-D-I-C-A-L G-R-O-U-P dot net — and include any additional details about your product or service. We appreciate your time and hope you have a wonderful day!`);
  twiml.hangup();
  clearSession(callSid);
  res.type('text/xml').send(twiml.toString());
});


// ═══════════════════════════════════════════════════════════════════════════════
// LAYER 1: GLOBAL EXPRESS ERROR HANDLER
// Catches any unhandled error thrown in a route and returns valid TwiML
// instead of a 502, then alerts all staff immediately.
// ═══════════════════════════════════════════════════════════════════════════════
app.use((err, req, res, next) => {
  const route = req.path || 'unknown';
  const callSid = (req.body && req.body.CallSid) || 'unknown';
  console.error(`[GLOBAL ERROR] Route: ${route} | CallSid: ${callSid} |`, err.message);

  // Alert staff immediately
  const alertSubject = `🚨 Taylor AI Error — Route: ${route}`;
  const alertHtml = `
    <div style="font-family:Arial,sans-serif;max-width:600px;margin:0 auto;padding:24px;">
      <h2 style="color:#c53030;">🚨 Taylor AI — Route Error Detected</h2>
      <table style="width:100%;border-collapse:collapse;">
        <tr><td style="padding:6px;font-weight:bold;background:#fff5f5">Route</td><td style="padding:6px">${route}</td></tr>
        <tr><td style="padding:6px;font-weight:bold;background:#fff5f5">Call SID</td><td style="padding:6px">${callSid}</td></tr>
        <tr><td style="padding:6px;font-weight:bold;background:#fff5f5">Error</td><td style="padding:6px;color:#c53030">${err.message}</td></tr>
        <tr><td style="padding:6px;font-weight:bold;background:#fff5f5">Time</td><td style="padding:6px">${new Date().toLocaleString('en-US', { timeZone: 'America/New_York' })}</td></tr>
      </table>
      <p style="margin-top:16px;color:#555">Taylor returned a graceful fallback to the caller. No 502 was sent. Please review and fix if needed.</p>
    </div>`;
  sendEmail(alertSubject, alertHtml, `Taylor AI Error\nRoute: ${route}\nCallSid: ${callSid}\nError: ${err.message}`).catch(() => {});

  // Return valid TwiML so the call doesn't go silent
  if (!res.headersSent) {
    const twiml = new VoiceResponse();
    say(twiml, "I'm sorry, I ran into a brief technical issue. Please hold while I connect you, or call us back at 6-7-8, 4-4-3, 4-0-0-0 and we'll be happy to help.");
    twiml.hangup();
    res.type('text/xml').status(200).send(twiml.toString());
  }
});

// ═══════════════════════════════════════════════════════════════════════════════
// LAYER 2: PROCESS-LEVEL CRASH GUARD
// Catches any unhandled promise rejection or uncaught exception at the Node.js
// process level — the last line of defense before the server dies.
// ═══════════════════════════════════════════════════════════════════════════════
process.on('unhandledRejection', (reason, promise) => {
  const msg = reason instanceof Error ? reason.message : String(reason);
  console.error('[UNHANDLED REJECTION]', msg);
  sendEmail(
    '🚨 Taylor AI — Unhandled Promise Rejection',
    `<div style="font-family:Arial,sans-serif;padding:24px;"><h2 style="color:#c53030;">Unhandled Promise Rejection</h2><p><strong>Reason:</strong> ${msg}</p><p><strong>Time:</strong> ${new Date().toLocaleString('en-US',{timeZone:'America/New_York'})}</p></div>`,
    `Unhandled rejection: ${msg}`
  ).catch(() => {});
});

process.on('uncaughtException', (err) => {
  console.error('[UNCAUGHT EXCEPTION]', err.message);
  sendEmail(
    '🚨 Taylor AI — Uncaught Exception (Server May Restart)',
    `<div style="font-family:Arial,sans-serif;padding:24px;"><h2 style="color:#c53030;">Uncaught Exception</h2><p><strong>Error:</strong> ${err.message}</p><p><strong>Stack:</strong> <pre>${(err.stack||'').slice(0,800)}</pre></p><p><strong>Time:</strong> ${new Date().toLocaleString('en-US',{timeZone:'America/New_York'})}</p></div>`,
    `Uncaught exception: ${err.message}`
  ).catch(() => {});
  // Do NOT call process.exit() — let Railway restart the process naturally
});

// ═══════════════════════════════════════════════════════════════════════════════
// LAYER 3: POST-DEPLOY SMOKE TEST
// Runs 45 seconds after server start. Hits all critical routes with synthetic
// POST requests and validates they return valid TwiML (200 + <Response> XML).
// Emails staff immediately if any route fails.
// ═══════════════════════════════════════════════════════════════════════════════
const SMOKE_TEST_ROUTES = [
  { path: '/voice',              body: { CallSid: 'smoke_test', From: '+10000000000', To: CONFIG.twilio.phoneNumber } },
  { path: '/appt-spell-name',    body: { CallSid: 'smoke_test', SpeechResult: 'E L D R E D' } },
  { path: '/refill-start',       body: { CallSid: 'smoke_test' } },
  { path: '/main-intent',        body: { CallSid: 'smoke_test', SpeechResult: 'book an appointment' } },
  { path: '/lead-start',         body: { CallSid: 'smoke_test' } },
];

async function runSmokeTests() {
  const PORT_LOCAL = process.env.PORT || 3000;
  const base = `http://localhost:${PORT_LOCAL}`;
  const results = [];
  for (const test of SMOKE_TEST_ROUTES) {
    try {
      const r = await axios.post(`${base}${test.path}`,
        new URLSearchParams(test.body).toString(),
        { headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, timeout: 8000 }
      );
      const ok = r.status === 200 && r.data && r.data.includes('<Response>');
      results.push({ path: test.path, status: r.status, ok });
    } catch (err) {
      results.push({ path: test.path, status: err.response?.status || 0, ok: false, error: err.message });
    }
  }
  const failed = results.filter(r => !r.ok);
  if (failed.length > 0) {
    const rows = results.map(r => `<tr><td style="padding:6px;background:${r.ok?'#f0fff4':'#fff5f5'}">${r.path}</td><td style="padding:6px;color:${r.ok?'green':'red'}">${r.ok?'✅ PASS':'❌ FAIL'}</td><td style="padding:6px">${r.status}</td><td style="padding:6px">${r.error||''}</td></tr>`).join('');
    const html = `<div style="font-family:Arial,sans-serif;padding:24px;"><h2 style="color:#c53030;">🚨 Taylor AI — Post-Deploy Smoke Test FAILED</h2><p>${failed.length} of ${results.length} routes failed after deploy.</p><table style="width:100%;border-collapse:collapse;"><tr style="background:#eee"><th style="padding:6px">Route</th><th style="padding:6px">Result</th><th style="padding:6px">HTTP</th><th style="padding:6px">Error</th></tr>${rows}</table><p style="margin-top:16px;color:#555">Time: ${new Date().toLocaleString('en-US',{timeZone:'America/New_York'})}</p></div>`;
    await sendEmail('🚨 Taylor AI — Smoke Test Failed After Deploy', html, `Smoke test failed: ${failed.map(f=>f.path).join(', ')}`).catch(()=>{});
    console.error('[SMOKE TEST] FAILED routes:', failed.map(f => f.path).join(', '));
  } else {
    console.log('[SMOKE TEST] All routes passed ✅');
  }
}


// ─── Silence / Pause Handler ──────────────────────────────────────────────────
// Called when a gather times out with no speech - asks "are you still there?"
// before hanging up, giving the caller one more chance to respond
app.post('/silence-check', (req, res) => {
  const twiml = new VoiceResponse();
  const callSid = req.body.CallSid;
  const attempt = parseInt(req.body.attempt || '1', 10);
  if (attempt >= 2) {
    // Second silence - hang up gracefully
    twiml.say({ voice: 'Polly.Joanna-Neural', language: 'en-US' },
      "We haven't heard from you, so we'll let you go for now. Please call us back at 678-443-4000 anytime. Have a wonderful day!");
    twiml.hangup();
  } else {
    // First silence - ask if still there
    const g = twiml.gather({ input: 'speech', speechTimeout: '3', timeout: 10, action: `/silence-check?attempt=2`, method: 'POST' });
    g.say({ voice: 'Polly.Joanna-Neural', language: 'en-US' },
      "Are you still there? Take your time — I'm here whenever you're ready.");
  }
  res.type('text/xml').send(twiml.toString());
});

// Silence check — ask "are you still there?" before hanging up
app.post('/silence-check', (req, res) => {
  const twiml = new VoiceResponse();
  const g = gather(twiml, '/silence-final', { input: 'speech', speechTimeout: '3', timeout: 8 });
  say(g, "Are you still there? If you need help, please say yes or press any key.");
  twiml.redirect('/silence-final');
  res.type('text/xml').send(twiml.toString());
});

app.post('/silence-final', (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase().trim();
  const twiml = new VoiceResponse();
  if (speech && speech.length > 0) {
    // They responded — send back to main menu
    twiml.redirect('/main-intent');
  } else {
    say(twiml, "Thank you for calling Taylor Medical Group. We look forward to helping you. Please call back at 678-443-4000 anytime. Have a wonderful day!");
    twiml.hangup();
  }
  res.type('text/xml').send(twiml.toString());
});


// ═══════════════════════════════════════════════════════════════════════════════
// SCHEDULED JOB — Daily 8 AM Intake Form Check & Auto-Cancel
//
// Runs at 8 AM ET every morning.
// Pulls ALL appointments scheduled for TOMORROW (next calendar day in ET).
// For each appointment, checks if the patient's intake forms are complete.
// If forms are NOT complete → cancels the appointment and notifies the patient
// via IntakeQ with the reason and instructions to reschedule.
//
// The 24-hour rule: at 8 AM, every appointment tomorrow is already within
// 24 hours of its specific scheduled time (e.g. 10 AM tomorrow = 26h away,
// 9 AM tomorrow = 25h away — both are past the 24h deadline window).
// This means Taylor cancels based on EACH patient's specific appointment time.
// ═══════════════════════════════════════════════════════════════════════════════
async function runDailyFormCheck() {
  console.log('[FORM CHECK] Starting daily 8 AM intake form check for TOMORROW\'s appointments...');
  const INTAKEQ_KEY = CONFIG.intakeq.apiKey;
  if (!INTAKEQ_KEY) { console.error('[FORM CHECK] No IntakeQ API key'); return; }

  try {
    // Get TOMORROW's date in ET timezone
    const nowET = new Date(new Date().toLocaleString('en-US', { timeZone: 'America/New_York' }));
    const tomorrowET = new Date(nowET);
    tomorrowET.setDate(tomorrowET.getDate() + 1);
    // Format as YYYY-MM-DD for IntakeQ API
    const tomorrowStr = tomorrowET.toISOString().split('T')[0];
    console.log(`[FORM CHECK] Checking appointments for: ${tomorrowStr}`);

    const apptResp = await axios.get(
      `${CONFIG.intakeq.baseUrl}/appointments?startDate=${tomorrowStr}&endDate=${tomorrowStr}&status=Confirmed,WaitingConfirmation`,
      { headers: { 'X-Auth-Key': INTAKEQ_KEY, 'Accept': 'application/json' }, timeout: 15000 }
    );
    const appointments = apptResp.data || [];
    console.log(`[FORM CHECK] Found ${appointments.length} appointments for tomorrow (${tomorrowStr})`);

    const cancelled = [];
    const confirmed = [];
    const formsSent = [];
    const skipped = [];

    // ── Form ID map by appointment type ────────────────────────────────────────────────────────────────
    // Determines which form to send based on service name keywords.
    // Returns null if this appointment type does NOT require forms (e.g. established follow-up).
    function getFormIdForAppointment(serviceName) {
      const s = (serviceName || '').toLowerCase();
      // New patient wellness/hormone
      if (s.includes('new patient') && (s.includes('wellness') || s.includes('hormone'))) {
        return '65071ef126699cd9ca73a217'; // New Wellness/Hormone Patient Intake Forms 2026
      }
      // New patient IV therapy
      if (s.includes('new patient') && s.includes('iv')) {
        return '68f155b2532a10cef8e90dfd'; // IV Therapy Intake Forms New Patient 2026
      }
      // New patient weight loss
      if (s.includes('new patient') && s.includes('weight')) {
        return '68f1553e532a10cef8e909ad'; // Weight Loss Intake Form New Patient 2026
      }
      // Any other new patient
      if (s.includes('new patient')) {
        return '65071ef126699cd9ca73a217'; // Default to New Wellness/Hormone Patient Intake Forms 2026
      }
      // Telehealth
      if (s.includes('telehealth')) {
        return '698be202c40cce55e17ffc57'; // Telehealth Visit Card Form 2026
      }
      // Annual visit (established patient)
      if (s.includes('annual')) {
        return '68f154eb532a10cef8e906ae'; // Annual Patient Intake Forms 2026
      }
      // Weight loss annual
      if (s.includes('weight') && s.includes('annual')) {
        return '6998df48f370ba086af28153'; // Weight Loss Annual Patient Forms
      }
      // No forms required for this appointment type
      return null;
    }

    for (const appt of appointments) {
      const apptId = appt.Id;
      const clientId = appt.ClientId;
      const clientName = appt.ClientName || 'Unknown Patient';
      const clientEmail = appt.ClientEmail || null;
      const apptTime = appt.StartDateLocalFormatted || appt.StartDate;
      const serviceName = appt.ServiceName || 'appointment';

      if (!clientId || !apptId) continue;

      // Determine if this appointment type requires forms
      const requiredFormId = getFormIdForAppointment(serviceName);
      if (!requiredFormId) {
        // Not a form-required appointment type — skip silently
        skipped.push({ name: clientName, time: apptTime, service: serviceName, reason: 'Not a form-required visit type' });
        console.log(`[FORM CHECK] Skipping ${clientName} (${serviceName}) — not a form-required visit type`);
        await new Promise(r => setTimeout(r, 300));
        continue;
      }

      try {
        // Check completed forms
        const formResp = await axios.get(
          `${CONFIG.intakeq.baseUrl}/intakes/summary?clientId=${clientId}&all=true`,
          { headers: { 'X-Auth-Key': INTAKEQ_KEY, 'Accept': 'application/json' }, timeout: 10000 }
        );
        const allForms = formResp.data || [];
        const completedForms = allForms.filter(f => f.Status === 'Completed');
        const pendingForms = allForms.filter(f => f.Status === 'Sent' || f.Status === 'Partial');

        const hasCompletedForms = completedForms.length > 0;
        const hasPendingForms = pendingForms.length > 0;

        if (hasCompletedForms) {
          // Forms already done — confirmed
          confirmed.push({ name: clientName, time: apptTime, service: serviceName });
          console.log(`[FORM CHECK] ✅ ${clientName} — forms complete`);

        } else if (hasPendingForms) {
          // Forms were sent but NOT completed — cancel (they had their chance)
          console.log(`[FORM CHECK] Cancelling ${clientName} (${apptTime}) — forms sent but not completed`);
          const cancelMsg = `Your appointment for ${serviceName} on ${apptTime} has been cancelled because your required patient intake forms were not completed before the 24-hour deadline.\n\nTo reschedule, please visit your patient portal at https://taylormedical.intakeq.com/portal, complete your intake forms, and book a new appointment.\n\nIf you have questions, please call us at 678-443-4000 or email info@taylormedicalgroup.net.\n\nWe look forward to seeing you soon!\n\nTaylor Medical Group`;
          await axios.patch(
            `${CONFIG.intakeq.baseUrl}/appointments/${apptId}`,
            { Status: 'Cancelled', CancellationReason: 'Patient did not complete required intake forms prior to the 24-hour deadline.', SendCancellationEmail: true, CancellationNote: cancelMsg },
            { headers: { 'X-Auth-Key': INTAKEQ_KEY, 'Content-Type': 'application/json' }, timeout: 10000 }
          );
          cancelled.push({ name: clientName, time: apptTime, service: serviceName, reason: 'Forms sent but not completed' });

        } else {
          // No forms at all — SEND the forms now, do NOT cancel yet
          console.log(`[FORM CHECK] Sending forms to ${clientName} (${serviceName}) — no forms on file`);
          try {
            const sendPayload = { QuestionnaireId: requiredFormId, ClientId: clientId };
            await axios.post(
              `${CONFIG.intakeq.baseUrl}/intakes/send`,
              sendPayload,
              { headers: { 'X-Auth-Key': INTAKEQ_KEY, 'Content-Type': 'application/json' }, timeout: 10000 }
            );
            formsSent.push({ name: clientName, time: apptTime, service: serviceName, formId: requiredFormId });
            console.log(`[FORM CHECK] 📨 Forms sent to ${clientName}`);
          } catch (sendErr) {
            console.error(`[FORM CHECK] Failed to send forms to ${clientName}:`, sendErr.response?.data || sendErr.message);
            // If send fails, flag for staff but do not cancel
            formsSent.push({ name: clientName, time: apptTime, service: serviceName, formId: requiredFormId, sendError: sendErr.message });
          }
        }
      } catch (clientErr) {
        console.error(`[FORM CHECK] Error checking forms for ${clientName}:`, clientErr.message);
      }

      // Small delay between API calls to avoid rate limiting
      await new Promise(r => setTimeout(r, 600));
    }

    // Send staff summary email
    if (cancelled.length > 0 || confirmed.length > 0) {
      const cancelledRows = cancelled.map(c =>
        `<tr><td style="padding:8px;color:#c53030;font-weight:bold;">${c.name}</td><td style="padding:8px;">${c.time}</td><td style="padding:8px;">${c.service}</td><td style="padding:8px;color:#c53030;">CANCELLED — No forms${c.hasPending ? ' (forms sent but not completed)' : ''}</td></tr>`
      ).join('');
      const confirmedRows = confirmed.map(c =>
        `<tr><td style="padding:8px;color:#276749;">${c.name}</td><td style="padding:8px;">${c.time}</td><td style="padding:8px;">${c.service}</td><td style="padding:8px;color:#276749;">CONFIRMED — Forms complete</td></tr>`
      ).join('');

      const html = `
        <div style="font-family:Arial,sans-serif;max-width:700px;padding:24px;">
          <h2 style="color:#2b6cb0;">&#128203; Taylor AI — Daily Form Check Report</h2>
          <p>Daily 8 AM intake form check completed. Tomorrow's appointments reviewed — each cancelled based on their specific appointment time (24-hour deadline):</p>
          <table style="width:100%;border-collapse:collapse;margin:16px 0;">
            <thead><tr style="background:#edf2f7;">
              <th style="padding:8px;text-align:left;">Patient</th>
              <th style="padding:8px;text-align:left;">Appointment Time</th>
              <th style="padding:8px;text-align:left;">Service</th>
              <th style="padding:8px;text-align:left;">Status</th>
            </tr></thead>
            <tbody>${cancelledRows}${confirmedRows}</tbody>
          </table>
          <p style="color:#718096;font-size:12px;">Cancelled patients have been notified via IntakeQ with instructions to reschedule after completing their forms.</p>
        </div>`;

      const subject = `&#128203; Daily Form Check: ${cancelled.length} cancelled, ${confirmed.length} confirmed — ${new Date().toLocaleDateString('en-US', {timeZone:'America/New_York'})}`;
      await sendEmail(subject, html, `Daily form check: ${cancelled.length} cancelled (no forms), ${confirmed.length} confirmed.`);
      console.log(`[FORM CHECK] Complete. Cancelled: ${cancelled.length}, Confirmed: ${confirmed.length}`);
    } else {
      console.log(`[FORM CHECK] No appointments found for tomorrow (${tomorrowStr}).`);
    }
  } catch (err) {
    console.error('[FORM CHECK] Fatal error:', err.message);
  }
}

// Schedule the daily form check at 8:00 AM ET every day
function scheduleDailyFormCheck() {
  function msUntilNext8amET() {
    const now = new Date();
    // Get current time in ET
    const etNow = new Date(now.toLocaleString('en-US', { timeZone: 'America/New_York' }));
    const next8am = new Date(etNow);
    next8am.setHours(8, 0, 0, 0);
    if (etNow >= next8am) next8am.setDate(next8am.getDate() + 1); // already past 8am, schedule for tomorrow
    return next8am - etNow;
  }

  const msUntilFirst = msUntilNext8amET();
  const hoursUntil = Math.round(msUntilFirst / 1000 / 60 / 60 * 10) / 10;
  console.log(`[FORM CHECK] Scheduled daily check in ${hoursUntil}h (next 8:00 AM ET)`);

  setTimeout(() => {
    runDailyFormCheck();
    // Then repeat every 24 hours
    setInterval(runDailyFormCheck, 24 * 60 * 60 * 1000);
  }, msUntilFirst);
}

app.listen(PORT, () => {
  console.log(`TMG AI Receptionist v7.36 "Taylor" running on port ${PORT}`);
  // Run smoke test 45 seconds after startup to allow Railway to fully initialize
  setTimeout(runSmokeTests, 45000);
  // Schedule daily 8 AM intake form check
  scheduleDailyFormCheck();
});
module.exports = app;
