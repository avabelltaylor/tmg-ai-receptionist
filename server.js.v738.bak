const app = express();
app.use(express.urlencoded({ extended: false }));
app.use(express.json());

// ─── Post-call booking verification: checks IntakeQ 90s after call ends ─────────
async function verifyBookingAfterCall(callSid, callerPhone, patientName, intendedAction) {
  if (!callSid || !intendedAction) return;
  try {
    const today = new Date();
    const startDate = new Date(today.setHours(0,0,0,0)).toISOString().split('T')[0];
    const endDate = new Date(today.setHours(23,59,59,999)).toISOString().split('T')[0];
    const resp = await axios.get(
      `${CONFIG.intakeq.baseUrl}/appointments?startDate=${startDate}&endDate=${endDate}&status=Confirmed,WaitingConfirmation`,
      { headers: { 'X-Auth-Key': CONFIG.intakeq.apiKey, 'Accept': 'application/json' }, timeout: 10000 }
    );
    const appts = resp.data || [];
    const firstName = (patientName || '').split(' ')[0]?.toLowerCase();
    const lastName = (patientName || '').split(' ').slice(1).join(' ')?.toLowerCase();
    const found = appts.some(a => {
      const clientName = (a.ClientName || '').toLowerCase();
      return (firstName && clientName.includes(firstName)) || (lastName && lastName.length > 1 && clientName.includes(lastName));
    });
    if (!found && intendedAction === 'booking') {
      console.warn(`[POST-CALL] Booking NOT found in IntakeQ for ${patientName} (${callerPhone}) — sending staff alert`);
      const subject = `⚠️ URGENT: Booking Failed — Call Back ${patientName || callerPhone}`;
      const html = `
        <div style="font-family:Arial,sans-serif;max-width:600px;padding:24px;">
          <h2 style="color:#c53030;">&#9888;&#65039; Booking Not Confirmed in IntakeQ</h2>
          <p>Taylor AI completed a booking flow with a caller, but <strong>no appointment was found in IntakeQ</strong> within 90 seconds of the call ending.</p>
          <table style="width:100%;border-collapse:collapse;margin:16px 0;">
            <tr><td style="padding:8px;font-weight:bold;">Patient Name:</td><td style="padding:8px;">${patientName || 'Unknown'}</td></tr>
            <tr style="background:#f7fafc;"><td style="padding:8px;font-weight:bold;">Phone:</td><td style="padding:8px;">${callerPhone || 'Unknown'}</td></tr>
            <tr><td style="padding:8px;font-weight:bold;">Call SID:</td><td style="padding:8px;">${callSid}</td></tr>
            <tr style="background:#f7fafc;"><td style="padding:8px;font-weight:bold;">Action:</td><td style="padding:8px;">${intendedAction}</td></tr>
          </table>
          <p style="color:#c53030;font-weight:bold;">Please call this patient back immediately to complete their booking.</p>
        </div>`;
      await sendEmail(subject, html, `URGENT: Booking not confirmed for ${patientName || callerPhone}. Please call back immediately.`);
    } else if (found) {
      console.log(`[POST-CALL] Booking VERIFIED in IntakeQ for ${patientName}`);
    }
  } catch (err) {
    console.error('[POST-CALL VERIFY]', err.message);
  }
}

// ─── Auto-transcript middleware: logs every caller speech turn ───────────────────
// Intercepts every POST from Twilio and logs SpeechResult to the transcript store.
// Taylor's responses are logged via the say() helper.
app.use((req, res, next) => {
  const callSid = req.body && req.body.CallSid;
  const speech = req.body && req.body.SpeechResult;
  const route = req.path;
  if (callSid && speech && speech.trim()) {
    logTurn(callSid, 'caller', speech.trim(), route);
  }
  next();
});

