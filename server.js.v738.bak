// ═══════════════════════════════════════════════════════════════════════════════
// ROUTE — Universal intake: collect callback phone number
// ═══════════════════════════════════════════════════════════════════════════════
app.post('/intake-phone', (req, res) => {
  const speech = (req.body.SpeechResult || '').trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);

  if (!speech || speech.length < 3) {
    const g = gather(twiml, '/intake-phone', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, "I'm sorry, I didn't catch that! What's the best number to reach you at?");
    return res.type('text/xml').send(twiml.toString());
  }

  // Store the callback number (use caller ID as fallback if they say 'same' or 'this number')
  const saidSame = /same|this number|this one|you have it|already have/.test(speech.toLowerCase());
  if (saidSame) {
    sess.collectedPhone = sess.callerPhone;
  } else {
    // Normalize spoken digits to E.164 format
    const digits = speech.replace(/\D/g, '').slice(-10);
    sess.collectedPhone = digits.length >= 10 ? `+1${digits}` : sess.callerPhone;
  }

  // Now ask how we can help
  const g = gather(twiml, '/main-intent', { input: 'speech', speechTimeout: '2', timeout: 15 });
  say(g, `Perfect, thank you ${sess.pronouncedName || sess.firstName}! How can I help you today?`);
  res.type('text/xml').send(twiml.toString());
});

app.post('/clinic/incoming', (req, res) => { req.url = '/voice'; app.handle(req, res); });

// ═══════════════════════════════════════════════════════════════════════════════
// ROUTE — Main intent handler (fully speech-driven)
// ═══════════════════════════════════════════════════════════════════════════════
app.post('/main-intent', (req, res) => {
  const speech = (req.body.SpeechResult || '').trim();
  const callSid = req.body.CallSid;
  const callerPhone = req.body.From || 'anonymous';
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  sess.callerPhone = callerPhone;
  sess.callLog = sess.callLog || [];

  const intent = detectIntent(speech);
  sess.callLog.push(`Intent: ${intent} | Speech: "${speech}"`);

  if (intent === 'emergency') {
    say(twiml, "If you are experiencing a medical emergency, please hang up right now and call 9-1-1 or go to your nearest emergency room. Taylor Med-ical Group does not provide emergency services. Please call 9-1-1 immediately.");
    twiml.hangup();
  } else if (intent === 'cancel') {
    twiml.redirect('/cancel-reschedule-info');
  } else if (intent === 'forms') {
    twiml.redirect('/forms-info');
  } else if (intent === 'records') {
    twiml.redirect('/records-info');
  } else if (intent === 'nonpatient') {
    twiml.redirect('/nonpatient-info');
  } else if (intent === 'sales') {
    twiml.redirect('/sales-start');
  } else if (intent === 'pharmacy') {
    twiml.redirect('/pharmacy-start');
  } else if (intent === 'transfer') {
    // Triage the caller before deciding what to do
    twiml.redirect('/transfer-triage');
  } else if (intent === 'voicemail') {
    twiml.redirect('/leave-message');
  } else if (intent === 'appointment') {
    // Check if caller already declared their patient type in the same utterance
    const speechLower = speech.toLowerCase();
    const alreadyEstablished = /established|existing|returning|been there|been a patient|follow.?up|come back|i have|i.ve been|been seen|already a patient|i.m a patient|current patient|i go there|been coming|my doctor|my provider|had an appointment|came in before|been for/.test(speechLower);
    const alreadyNew = /new patient|first time|never been|haven.t been|first visit|never seen|brand new|just moved|just found|want to become/.test(speechLower);
    if (alreadyEstablished) {
      sess.patientType = 'established';
      const g = gather(twiml, '/appt-service-type', { input: 'speech', speechTimeout: '2', timeout: 12 });
      say(g, "Welcome back! It's great to hear from you. What type of visit are you scheduling today — a follow-up, annual wellness visit, telehealth, IV therapy, or something else?");
    } else if (alreadyNew) {
      sess.patientType = 'new';
      const g = gather(twiml, '/lead-collect-name', { input: 'speech', speechTimeout: '2', timeout: 12 });
      say(g, "Wonderful! We'd love to have you. Let me get a little information first. What is your full name?");
    } else {
      const g = gather(twiml, '/appt-patient-type', { timeout: 10 });
      say(g, "Oh absolutely, I would love to help you get that scheduled! Are you a new patient with us, or an existing patient?");
    }
  } else if (intent === 'refill') {
    twiml.redirect('/refill-start');
  } else if (intent === 'labs' || intent === 'portal') {
    say(twiml, "Of course! Great news — you can check your lab results, view your prescriptions, request refills, and message our team any time through the patient portal. I'm texting you the link right now!");
    sendSms(callerPhone, `Taylor Medical Group — Patient Portal:\n${CONFIG.intakeq.portalUrl}\n\nView lab results, prescriptions, request refills, and message our team 24/7.`).catch(() => {});
    sendCallSummaryToStaff(callerPhone, `Reason: Lab results / portal access\nOutcome: Portal link sent`).catch(() => {});
    const g = gather(twiml, '/main-intent', { timeout: 8 });
    say(g, "Is there anything else I can do for you today?");
    twiml.hangup();
  } else if (intent === 'directions') {
    twiml.redirect('/directions-info');
  } else if (intent === 'hours') {
    say(twiml, "Great question! Our phones are available Monday through Friday, 9 AM to 5 PM Eastern. We see patients in the office on Mondays, Thursdays, and Fridays from 10 AM to 5 PM — and Fridays we wrap up at 3. You can also book online any time — I'm sending you the link right now!");
    sendSms(callerPhone, `Taylor Medical Group — Book an Appointment:\n${CONFIG.intakeq.bookingUrl}\n\nPatient appointments: Mon, Thu & Fri, 10am–5pm ET (Fri closes 3pm)\nOffice admin: Mon–Fri, 9am–5pm`).catch(() => {});
    const g = gather(twiml, '/main-intent', { timeout: 8 });
    say(g, "Is there anything else I can do for you today?");
    twiml.hangup();
  } else if (intent === 'telehealth') {
    twiml.redirect('/telehealth-info');
  } else if (intent === 'children') {
    say(twiml, "Yes, we do see children as long as they are cooperative. I'd be happy to get them scheduled! Are you calling to book a new patient visit for your child?");
    sendSms(callerPhone, `Taylor Medical Group — Book an Appointment:\n${CONFIG.intakeq.bookingUrl}\n\nWe see children as long as they are cooperative. Book online 24/7 or call 678-443-4000.`).catch(() => {});
    const g = gather(twiml, '/appt-patient-type', { timeout: 10 });
    say(g, "Would you like to schedule an appointment?");
  } else if (intent === 'iv') {
    twiml.redirect('/iv-info');
  } else if (intent === 'services') {
    twiml.redirect('/services-info');
  } else if (intent === 'billing') {
    twiml.redirect('/billing-info');
  } else if (intent === 'fax') {
    say(twiml, "Our fax number is 6 7 8, 4 4 3, 4 0 9 0. Is there anything else I can help you with?");
    const g = gather(twiml, '/main-intent', { timeout: 8 }); say(g, ""); twiml.hangup();
  } else if (intent === 'email') {
    // Email address only for sales/pharmacy callers — patients use portal only
    const isSalesOrPharmacy = sess._callerType === 'sales' || sess._callerType === 'pharmacy';
    if (isSalesOrPharmacy) {
      say(twiml, "You can reach us by email at info at taylor medical group dot net. Is there anything else I can help you with?");
      const g = gather(twiml, '/main-intent', { timeout: 8 }); say(g, ''); twiml.hangup();
    } else {
      // Patient or unknown — redirect to portal, no email given
      say(twiml, "Please note that we do not accept emails from patients — all requests and communications must go through the patient portal. Please visit Taylor Medical Group dot net and click Patient Portal in the top right corner. You can message the doctors directly there and they will personally respond. I'm sending you the portal link right now.");
      const patientEmail = sess.emailOnFile || sess.patientRecord?.Email || null;
      if (patientEmail) sendPortalLinkToPatient(patientEmail, sess.pronouncedName || sess.firstName || '').catch(() => {});
      sendCallSummaryToStaff(callerPhone, `Reason: Caller asked for email — redirected to portal`).catch(() => {});
      const g = gather(twiml, '/main-intent', { input: 'speech', speechTimeout: '2', timeout: 10 });
      say(g, 'Is there anything else I can help you with today?');
      twiml.hangup();
    }
  } else {
    // Unknown intent — take message and text staff immediately
    if (speech && speech.length > 3) {
      sess.callLog.push(`Unknown question: "${speech}"`);
      const callerName = sess.firstName ? `${sess.firstName} ${sess.lastName || ''}`.trim() : 'Caller';
      escalateToStaff(callerPhone, `💬 Message from ${callerName}`, `Caller: ${callerName}\nPhone: ${callerPhone}\nMessage: ${speech}`).catch(() => {});
      say(twiml, "I've sent your message to our team and they'll follow up with you shortly. Is there anything else I can help you with today?");
      const g = gather(twiml, '/main-intent', { input: 'speech', speechTimeout: '2', timeout: 10 });
      say(g, "");
      twiml.hangup();
    } else {
      const g = gather(twiml, '/main-intent', { timeout: 10 });
      say(g, "I'm here to help! You can tell me what you need — for example, you can say 'I'd like to schedule an appointment,' 'I need a prescription refill,' or 'I need directions to the office.'");
      twiml.redirect('/voice');
    }
  }
  res.type('text/xml').send(twiml.toString());
});

// ═══════════════════════════════════════════════════════════════════════════════
// ROUTE — Unknown intent choice (voicemail or portal)
// ═══════════════════════════════════════════════════════════════════════════════
app.post('/unknown-choice', (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase();
  const callerPhone = req.body.From || 'anonymous';
  const twiml = new VoiceResponse();
  if (/message|voicemail|leave|record/.test(speech)) {
    twiml.redirect('/leave-message');
  } else {
    say(twiml, "Absolutely! I want to make sure you get the right help, so I'm sending you the patient portal link right now. You can message the doctors directly there and they will personally get back to you. You're in great hands!");
    sendSms(callerPhone, `Taylor Medical Group — Message our doctors:\n${CONFIG.intakeq.portalUrl}\n\nOr visit: www.taylormedicalgroup.net`).catch(() => {});
    sendCallSummaryToStaff(callerPhone, `Reason: Unknown question — portal link sent`).catch(() => {});
    const g = gather(twiml, '/main-intent', { timeout: 8 });
    say(g, "Is there anything else I can do for you today?");
    twiml.hangup();
  }
  res.type('text/xml').send(twiml.toString());
});

// ═══════════════════════════════════════════════════════════════════════════════
// ROUTE — Leave a voicemail message
// ═══════════════════════════════════════════════════════════════════════════════
app.post('/leave-message', (req, res) => {
  const callSid = req.body.CallSid;
  const callerPhone = req.body.From || 'anonymous';
  const sess = getSession(callSid);
  sess.callerPhone = callerPhone;
  const twiml = new VoiceResponse();
  say(twiml, "Of course! Please leave a detailed message after the tone — include your name, phone number, and the reason for your call. Our team will follow up with you personally. Go ahead whenever you're ready.");
  twiml.record({
    action: '/message-recorded',
    method: 'POST',
    maxLength: 120,
    timeout: 5,
    transcribe: true,
    transcribeCallback: '/message-transcribed',
    playBeep: true,
  });
  say(twiml, "I didn't hear anything. Please call us back at 678-443-4000 or visit Taylor Medical Group dot net. Thank you!");
  twiml.hangup();
  res.type('text/xml').send(twiml.toString());
});

// ═══════════════════════════════════════════════════════════════════════════════
// ROUTE — Message recorded callback
// ═══════════════════════════════════════════════════════════════════════════════
app.post('/message-recorded', async (req, res) => {
  const callSid = req.body.CallSid;
  const callerPhone = req.body.From || 'anonymous';
  const recordingUrl = req.body.RecordingUrl;
  const recordingSid = req.body.RecordingSid;
  const sess = getSession(callSid);
  sess.callLog = sess.callLog || [];
  sess.callLog.push(`Voicemail recorded: ${recordingUrl}`);

  const twiml = new VoiceResponse();
  say(twiml, "Thank you so much for leaving a message! Our team will review it and follow up with you personally. We look forward to speaking with you. Have a wonderful day!");
  twiml.hangup();

  // Send immediate notification (transcription may come separately via /message-transcribed)
  await sendVoicemailToStaff(
    callerPhone,
    '(Transcription in progress — check recording link)',
    recordingUrl ? `${recordingUrl}.mp3` : null
  ).catch(() => {});

  sendCallSummaryToStaff(callerPhone, `Reason: Voicemail left\nRecording: ${recordingUrl || 'N/A'}\nRecording SID: ${recordingSid || 'N/A'}`).catch(() => {});
  clearSession(callSid);
  res.type('text/xml').send(twiml.toString());
});

// ═══════════════════════════════════════════════════════════════════════════════
// ROUTE — Transcription callback (fires when Twilio finishes transcribing)
// ═══════════════════════════════════════════════════════════════════════════════
app.post('/message-transcribed', async (req, res) => {
  const callerPhone = req.body.From || req.body.Called || 'unknown';
  const transcriptionText = req.body.TranscriptionText || '';
  const transcriptionStatus = req.body.TranscriptionStatus || '';
  const recordingUrl = req.body.RecordingUrl;

  console.log(`[TRANSCRIPTION] Status: ${transcriptionStatus} | Caller: ${callerPhone}`);

  if (transcriptionStatus === 'completed' && transcriptionText) {
    await sendVoicemailToStaff(
      callerPhone,
      transcriptionText,
      recordingUrl ? `${recordingUrl}.mp3` : null
    ).catch(() => {});
  }
  res.sendStatus(204);
});

// ═══════════════════════════════════════════════════════════════════════════════
// ROUTE — Directions
// ═══════════════════════════════════════════════════════════════════════════════
app.post('/directions-info', (req, res) => {
  const callerPhone = req.body.From || 'anonymous';
  const twiml = new VoiceResponse();
  say(twiml, "We're located at 5901 Peachtree Dunwoody Road, Building C, Suite C25, in Sandy Springs, Georgia 30328. We're in the Palisades Office Complex, right across from the King and Queen buildings. As you enter the complex, our building is the first one on the right — look for the large green metal letter C out front. Park in the deck for Building C, take the elevator down to level T for the tunnel, and we're the first suite on your left. I'm sending you the Google Maps link and directions to your email on file right now.");
  sendSms(callerPhone, `Taylor Medical Group\n5901 Peachtree Dunwoody Rd, Bldg C, Suite C25\nSandy Springs, GA 30328\n\n📍 Maps: ${CONFIG.practice.mapsLink}\n🎥 Directions video: ${CONFIG.practice.youtubeNewPatient}\n\nPhone: 678-443-4000`).catch(() => {});
  sendCallSummaryToStaff(callerPhone, `Reason: Directions\nOutcome: Maps + video sent`).catch(() => {});
  const g = gather(twiml, '/main-intent', { timeout: 8 }); say(g, "Is there anything else I can help you with today?"); twiml.hangup();
  res.type('text/xml').send(twiml.toString());
});

// ═══════════════════════════════════════════════════════════════════════════════
// ROUTE — Billing / Pricing
// ═══════════════════════════════════════════════════════════════════════════════
app.post('/billing-info', async (req, res) => {
  const callerPhone = req.body.From || 'anonymous';
  const speech = (req.body.SpeechResult || '').toLowerCase();
  const twiml = new VoiceResponse();
  let response = '';

  // Try live IntakeQ pricing first for specific service queries
  if (!/invoice|my bill|my balance|what do i owe|my account|my charges/.test(speech)) {
    const liveService = await findServicePrice(speech).catch(() => null);
    if (liveService && liveService.Price > 0) {
      const priceStr = `$${liveService.Price % 1 === 0 ? liveService.Price.toFixed(0) : liveService.Price.toFixed(2)}`;
      const durationStr = liveService.Duration ? ` (${liveService.Duration} minutes)` : '';
      response = `The current price for ${liveService.Name.trim()} is ${priceStr}${durationStr}. We don't accept insurance, but we do accept HSA and FSA cards. I'm sending you the booking link now.`;
      say(twiml, response);
      sendSms(callerPhone, `TMG Pricing — ${liveService.Name.trim()}\n${priceStr}${durationStr}\n\nBook: ${CONFIG.intakeq.bookingUrl}\nHSA/FSA accepted.`).catch(() => {});
      sendCallSummaryToStaff(callerPhone, `Reason: Pricing inquiry\nService: ${liveService.Name}\nPrice: ${priceStr}`).catch(() => {});
      const g = gather(twiml, '/main-intent', { timeout: 8 }); say(g, 'Is there anything else I can help you with today?'); twiml.hangup();
      return res.type('text/xml').send(twiml.toString());
    }
  }
  let smsBody = '';

  if (/iron infusion/.test(speech)) {
    response = "Yes, we absolutely offer iron infusion therapy. We don't accept insurance, but we do accept HSA and FSA cards, and we offer financing through CareCredit. I'm sending you our booking link with full pricing right now — would you like me to schedule an appointment for you today?";
    smsBody = `TMG Iron Infusions — Book & Pricing:\n${CONFIG.intakeq.bookingUrl}`;
  } else if (/vitamin c|high dose c/.test(speech)) {
    response = "We do offer high-dose Vitamin C IV therapy. For current pricing, please visit our booking link. I'm sending it to you now.";
    smsBody = `TMG Vitamin C IV — Book & Pricing:\n${CONFIG.intakeq.bookingUrl}`;
  } else if (/glutathione/.test(speech)) {
    response = "We do offer glutathione IV therapy. For current pricing, please visit our booking link. I'm sending it to you now.";
    smsBody = `TMG Glutathione IV — Book & Pricing:\n${CONFIG.intakeq.bookingUrl}`;
  } else if (/ozone iv/.test(speech)) {
    response = "We do offer ozone IV therapy. For current pricing, please visit our booking link. I'm sending it to you now.";
    smsBody = `TMG Ozone IV — Book & Pricing:\n${CONFIG.intakeq.bookingUrl}`;
  } else if (/hydrogen peroxide/.test(speech)) {
    response = "We do offer hydrogen peroxide IV therapy. For current pricing, please visit our booking link. I'm sending it to you now.";
    smsBody = `TMG Hydrogen Peroxide IV — Book & Pricing:\n${CONFIG.intakeq.bookingUrl}`;
  } else if (/nad/.test(speech)) {
    response = "We do offer NAD IV therapy. For current pricing, please visit our booking link. I'm sending it to you now.";
    smsBody = `TMG NAD IV — Book & Pricing:\n${CONFIG.intakeq.bookingUrl}`;
  } else if (/hydration/.test(speech)) {
    response = "We do offer hydration IV therapy. For current pricing, please visit our booking link. I'm sending it to you now.";
    smsBody = `TMG Hydration IV — Book & Pricing:\n${CONFIG.intakeq.bookingUrl}`;
  } else if (/ketamine/.test(speech)) {
    response = "We do offer ketamine IV therapy. For current pricing, please visit our booking link. I'm sending it to you now.";
    smsBody = `TMG Ketamine IV — Book & Pricing:\n${CONFIG.intakeq.bookingUrl}`;
  } else if (/myers/.test(speech)) {
    response = "We do offer the Myers Cocktail IV. For current pricing, please visit our booking link. I'm sending it to you now.";
    smsBody = `TMG Myers Cocktail IV — Book & Pricing:\n${CONFIG.intakeq.bookingUrl}`;
  } else if (/chelation|dtpa|edta/.test(speech)) {
    response = "We do offer chelation IV therapy. For current pricing, please visit our booking link. I'm sending it to you now.";
    smsBody = `TMG Chelation IV — Book & Pricing:\n${CONFIG.intakeq.bookingUrl}`;
  } else if (/magnesium/.test(speech)) {
    response = "We do offer magnesium IV therapy. For current pricing, please visit our booking link. I'm sending it to you now.";
    smsBody = `TMG Magnesium IV — Book & Pricing:\n${CONFIG.intakeq.bookingUrl}`;
  } else if (/saliva|hormone test|hormone kit/.test(speech)) {
    response = "We do offer saliva hormone testing kits. For current pricing, please visit our booking link. I'm sending it to you now.";
    smsBody = `TMG Saliva Hormone Testing — Book & Pricing:\n${CONFIG.intakeq.bookingUrl}\nHormone video: ${CONFIG.practice.youtubeHormone}`;
  } else if (/invoice|my bill|my balance|what do i owe|my account|my charges/.test(speech)) {
    response = "To view your invoices and account balance, please log in to your patient portal. I'm sending you the portal link by both text and email right now.";
    smsBody = `TMG Patient Portal (view invoices):\n${CONFIG.intakeq.portalUrl}`;
  } else if (/office visit|new patient|follow.?up|established|initial visit|evaluation|cost of a visit|price of a visit/.test(speech)) {
    response = "For current visit pricing, please visit our booking link where all service options and details are listed. We don't accept insurance, but we do accept HSA and FSA cards. I'm sending you the booking link now.";
    smsBody = `TMG Visit Booking & Pricing:\n${CONFIG.intakeq.bookingUrl}\nHSA/FSA accepted.`;
  } else {
    response = "For current pricing on any of our services, please visit our booking link or our website at www.taylormedicalgroup.net. Prices are always up to date there. I'm sending you the link by both text and email.";
    smsBody = `TMG Booking & Pricing:\n${CONFIG.intakeq.bookingUrl}\nWebsite: www.taylormedicalgroup.net`;
  }

  say(twiml, response);
  if (smsBody) sendSms(callerPhone, smsBody).catch(() => {});
  sendCallSummaryToStaff(callerPhone, `Reason: Billing/pricing\nSpeech: "${speech}"`).catch(() => {});
  const g = gather(twiml, '/main-intent', { timeout: 8 }); say(g, "Is there anything else I can help you with today?"); twiml.hangup();
  res.type('text/xml').send(twiml.toString());
});

