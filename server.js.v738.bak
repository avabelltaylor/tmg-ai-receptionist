app.post('/nonpatient-message', async (req, res) => {
  const speech = (req.body.SpeechResult || '').trim();
  const callerPhone = req.body.From || 'anonymous';
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  if (!speech) {
    const g = gather(twiml, '/nonpatient-message', { input: 'speech', speechTimeout: '2', timeout: 20 });
    say(g, "I didn't catch that. Please go ahead and leave your message for our team.");
    return res.type('text/xml').send(twiml.toString());
  }
  const callerName = sess.firstName ? `${sess.firstName} ${sess.lastName || ''}`.trim() : 'Non-patient caller';
  const subject = `💬 Non-Patient Message from ${callerName}`;
  const body = `Caller Phone: ${callerPhone}\nCaller Name: ${callerName}\nMessage: ${speech}\n\nNote: This caller is not a patient. Please review and respond as appropriate.`;
  await sendEmail(subject,
    `<div style="font-family:Arial,sans-serif;max-width:600px">
      <h2 style="color:#2c5282;">Non-Patient Message</h2>
      <p><strong>Phone:</strong> ${callerPhone}</p>
      <p><strong>Name:</strong> ${callerName}</p>
      <p><strong>Message:</strong></p>
      <blockquote style="border-left:4px solid #2c5282;padding-left:12px;color:#333">${speech}</blockquote>
      <p style="color:#718096;font-size:12px">Received via Taylor AI Receptionist</p>
    </div>`, body).catch(() => {});
  sendCallSummaryToStaff(callerPhone, `Reason: Non-patient message\nCaller: ${callerName}\nMessage: ${speech}\nOutcome: Staff emailed`).catch(() => {});
  say(twiml, "Perfect! I've sent your message to our team and they'll follow up with you. Is there anything else I can help you with today?");
  const g = gather(twiml, '/main-intent', { input: 'speech', speechTimeout: '2', timeout: 10 });
  say(g, '');
  twiml.hangup();
  res.type('text/xml').send(twiml.toString());
});

// ═══════════════════════════════════════════════════════════════════════════════
// ROUTE — Transfer triage: ask caller type before deciding what to do
// ═══════════════════════════════════════════════════════════════════════════════
app.post('/transfer-triage', (req, res) => {
  const twiml = new VoiceResponse();
  const g = gather(twiml, '/transfer-triage-response', { input: 'speech', speechTimeout: '2', timeout: 12 });
  say(g, "Of course! Before I connect you, are you a new patient, an existing patient, or are you calling from a pharmacy?");
  twiml.redirect('/transfer-triage-response');
  res.type('text/xml').send(twiml.toString());
});

app.post('/transfer-triage-response', (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase().trim();
  const callerPhone = req.body.From || 'anonymous';
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);

  const isNewPatient = /new patient|first time|never been|first visit|brand new|just found|want to become|new here/.test(speech);
  const isExistingPatient = /existing|established|returning|been there|been a patient|follow.?up|come back|i have|i.ve been|been seen|already a patient|i.m a patient|current patient|i go there|my doctor|my provider/.test(speech);
  const isPharmacy = /pharmacy|pharmacist|drug store|walgreens|cvs|rite aid|prescription|medication|refill/.test(speech);
  const isSales = /sales|vendor|representative|rep\b|business|company|product|service|solution|software|platform|account executive|account manager|reaching out/.test(speech);

  if (isNewPatient) {
    sess.patientType = 'new';
    const g = gather(twiml, '/lead-collect-name', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, "Wonderful! We'd love to have you as a new patient. Let me get a little information to get you started. What is your full name?");
  } else if (isExistingPatient) {
    sess.patientType = 'established';
    twiml.redirect('/appt-patient-type');
  } else if (isPharmacy) {
    twiml.redirect('/pharmacy-start');
  } else if (isSales) {
    twiml.redirect('/sales-start');
  } else if (!speech) {
    // No speech — re-ask
    const g = gather(twiml, '/transfer-triage-response', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, "I'm sorry, I didn't catch that. Are you a new patient, an existing patient, or calling from a pharmacy?");
    twiml.redirect('/transfer-triage-response');
  } else {
    // Unknown — ask if sales
    const g = gather(twiml, '/transfer-sales-check', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, "Got it. Is this a sales or business call?");
    twiml.redirect('/transfer-sales-check');
  }
  res.type('text/xml').send(twiml.toString());
});

app.post('/transfer-sales-check', (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase().trim();
  const callerPhone = req.body.From || 'anonymous';
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);

  const isYes = /yes|yeah|yep|correct|that.s right|it is|sales|business|vendor|rep/.test(speech);
  const isNo = /no|nope|not really|not a sales|not sales|patient|personal/.test(speech);

  if (isYes) {
    // Sales call — take info and give business email with disclaimer
    sess._callerType = 'sales';
    const g = gather(twiml, '/sales-collect-info', { input: 'speech', speechTimeout: '2', timeout: 20 });
    say(g, "No problem! Please go ahead and tell me your name, your company, and what product or service you're offering. I'll make sure our team gets your information.");
  } else if (isNo) {
    // Not sales — take a message for staff
    const g = gather(twiml, '/take-message-content', { input: 'speech', speechTimeout: '2', timeout: 20 });
    say(g, "Of course! Please go ahead and leave a detailed message for our team and they will follow up with you shortly.");
  } else {
    // No clear answer — default to take message
    const g = gather(twiml, '/take-message-content', { input: 'speech', speechTimeout: '2', timeout: 20 });
    say(g, "Of course! Please go ahead and leave a detailed message for our team and they will follow up with you shortly.");
  }
  res.type('text/xml').send(twiml.toString());
});

