});

app.post('/appt-collect-phone', (req, res) => {
  const speech = (req.body.SpeechResult || '').trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  if (!speech) {
    const g = gather(twiml, '/appt-collect-phone', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, pick(RETRY_PROMPTS) + ' What is your phone number?');
    return res.type('text/xml').send(twiml.toString());
  }
  // Escape hatch
  const esc = checkEscape(speech, sess, { noPivot: true });
  if (esc.action === 'correct') {
    const g = gather(twiml, '/appt-collect-dob', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, "No problem! Let me get your date of birth again — what is it?");
    return res.type('text/xml').send(twiml.toString());
  }
  if (esc.action === 'exit') {
    say(twiml, "Of course! Have a wonderful day — don't hesitate to call us if you need anything!");
    twiml.hangup();
    return res.type('text/xml').send(twiml.toString());
  }
  if (esc.action === 'pivot') {
    twiml.redirect('/main-intent');
    return res.type('text/xml').send(twiml.toString());
  }
  // Store raw speech, read back for confirmation
  const cleanDigits = speech.replace(/\D/g, '').slice(-10);
  const formatted = cleanDigits.length === 10
    ? `${cleanDigits.slice(0,3)}-${cleanDigits.slice(3,6)}-${cleanDigits.slice(6)}`
    : speech;
  sess._pendingPhone = speech;
  sess._pendingPhoneFormatted = formatted;
  // Speak digits individually without dashes to avoid TTS distortion
  // Group phone naturally: 678... 570... 2211
  const spokenPhone = cleanDigits.length === 10
    ? `${cleanDigits.slice(0,3)}... ${cleanDigits.slice(3,6)}... ${cleanDigits.slice(6)}`
    : speech.replace(/\D/g, '').replace(/(\d{3})(\d{3})(\d{4})/, '$1... $2... $3');
  const g = gather(twiml, '/appt-confirm-phone', { input: 'speech', speechTimeout: '3', timeout: 12 });
  say(g, `I have your phone number as ${spokenPhone}. Is that correct?`);
  res.type('text/xml').send(twiml.toString());
});

app.post('/appt-confirm-phone', async (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase().trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  const confirmed = /yes|correct|right|good|that.?s right|yep|yeah|uh.?huh/.test(speech);
  if (!confirmed) {
    const g = gather(twiml, '/appt-collect-phone', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, "No problem! Let me get your phone number again — what is it?");
    return res.type('text/xml').send(twiml.toString());
  }
  sess.collectedPhone = sess._pendingPhone;
  delete sess._pendingPhone;
  delete sess._pendingPhoneFormatted;
  // Update phone in IntakeQ if existing patient
  if (sess.existingClientId) {
    await updatePatientContact(sess.existingClientId, { Phone: sess.collectedPhone, CellPhone: sess.collectedPhone }).catch(() => {});
  }
  if (sess.patientType === 'new') {
    // New patient: collect DOB next (then address, sex, insurance before creating full chart)
    const g = gather(twiml, '/appt-new-collect-dob', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, `${pick(AFFIRMATIONS)} And what is your date of birth?`);
  } else {
    // Read back all collected info before lookup so caller can correct anything
    const fullName = `${sess.firstName || ''} ${sess.lastName || ''}`.trim();
    const dobSpoken = sess.dob || 'not provided';
    const phoneDigits = (sess.collectedPhone || '').replace(/\D/g, '').slice(-10);
    const phoneSpoken = phoneDigits.length === 10
    ? `${phoneDigits.slice(0,3)}... ${phoneDigits.slice(3,6)}... ${phoneDigits.slice(6)}`
    : (sess.collectedPhone || 'not provided');
    const g = gather(twiml, '/appt-confirm-info', { input: 'speech', speechTimeout: '2', timeout: 15 });
    say(g, `Perfect! Just to confirm everything before I look you up — I have your name as ${fullName}, date of birth ${dobSpoken}, and phone number ${phoneSpoken}. Is all of that correct?`);
  }
  res.type('text/xml').send(twiml.toString());
});

app.post('/appt-confirm-info', async (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase().trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  const confirmed = /yes|correct|right|good|that.?s right|yep|yeah|uh.?huh|sounds good|looks good|perfect/.test(speech);
  if (!confirmed) {
    // Caller wants to correct something — ask what needs fixing
    const g = gather(twiml, '/appt-confirm-info-fix', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, "No problem at all! What would you like to correct — your name, date of birth, or phone number?");
    return res.type('text/xml').send(twiml.toString());
  }
  say(twiml, `${pick(AFFIRMATIONS)} Let me pull up your account — just one moment.`);
  twiml.redirect('/appt-verify-existing');
  res.type('text/xml').send(twiml.toString());
});

app.post('/appt-confirm-info-fix', (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase().trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  if (/name|first|last/.test(speech)) {
    const g = gather(twiml, '/appt-collect-name', { input: 'speech', speechTimeout: '2', timeout: 10 });
    say(g, "Of course! Let’s get your name again — what is your first and last name?");
  } else if (/birth|dob|date/.test(speech)) {
    const g = gather(twiml, '/appt-collect-dob', { input: 'speech', speechTimeout: '2', timeout: 10 });
    say(g, "No problem! What is your date of birth?");
  } else if (/phone|number/.test(speech)) {
    const g = gather(twiml, '/appt-collect-phone', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, "Sure! What is your phone number?");
  } else {
    // Unclear — ask again
    const g = gather(twiml, '/appt-confirm-info-fix', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, "I’m sorry, I didn’t catch that. Would you like to correct your name, date of birth, or phone number?");
  }
  res.type('text/xml').send(twiml.toString());
});

// ═══════════════════════════════════════════════════════════════════════════════
// ROUTE — Verify existing patient identity via name+DOB lookup, confirm/update contact info, then PIN
// ═══════════════════════════════════════════════════════════════════════════════
app.post('/appt-verify-existing', async (req, res) => {
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  try {
    // Look up patient in IntakeQ by NAME + DOB (primary identifiers — phone may have changed)
    const client = await findPatientByNameAndDob(sess.firstName || '', sess.lastName || '', sess.dob || '', sess.collectedPhone || sess.callerPhone);
    if (!client) {
      // Not found — treat as new patient lead
      say(twiml, `I wasn't able to find your record in our system. Let me go ahead and get you set up as a new patient.`);
      twiml.redirect('/lead-collect-email');
      return res.type('text/xml').send(twiml.toString());
    }
    // IntakeQ search API returns: Email, Name, Phone, ClientNumber
    const clientId = client.ClientNumber || client.ClientId || client.Id;
    sess.existingClientId = clientId;
    sess.existingClient = client;

    // Read back contact info on file — use exact IntakeQ field names
    const phoneOnFile = client.Phone || 'not on file';
    const emailOnFile = client.Email || 'not on file';
    sess.phoneOnFile = phoneOnFile;
    sess.emailOnFile = emailOnFile;

    // Hydrate address from IntakeQ record so it appears in call summaries
    const addrParts = [
      client.Address || client.StreetAddress || '',
      client.City || '',
      client.State || client.StateShort || '',
      client.PostalCode || client.ZipCode || ''
    ].filter(Boolean);
    const addressOnFile = addrParts.length > 0 ? addrParts.join(', ') : null;
    if (addressOnFile) sess.address = addressOnFile;
    sess.addressOnFile = addressOnFile;

    // Ask patient to confirm contact info — include address if on file
    const g = gather(twiml, '/appt-confirm-contact', { input: 'speech', speechTimeout: '2', timeout: 10 });
    if (addressOnFile) {
      const phoneOnFileDigits = (phoneOnFile || '').replace(/\D/g, '').slice(-10);
      const phoneOnFileSpoken = phoneOnFileDigits.length === 10
        ? `${phoneOnFileDigits.slice(0,3)}... ${phoneOnFileDigits.slice(3,6)}... ${phoneOnFileDigits.slice(6)}`
        : (phoneOnFile || 'not provided');
      say(g, `I found your account! I have your phone number as ${phoneOnFileSpoken}, your email as ${spellOutEmail(emailOnFile)}, and your address as ${addressOnFile}. Is all of that still correct?`);
    } else {
      const phoneOnFileDigits2 = (phoneOnFile || '').replace(/\D/g, '').slice(-10);
      const phoneOnFileSpoken2 = phoneOnFileDigits2.length === 10
        ? `${phoneOnFileDigits2.slice(0,3)}... ${phoneOnFileDigits2.slice(3,6)}... ${phoneOnFileDigits2.slice(6)}`
        : (phoneOnFile || 'not provided');
      say(g, `I found your account! I have your phone number as ${phoneOnFileSpoken2} and your email as ${spellOutEmail(emailOnFile)}. Is all of that still correct?`);
    }
  } catch (err) {
    console.error('[VERIFY EXISTING]', err.message);
    say(twiml, `I had a little trouble pulling up your account, but no worries — let me go ahead and check our schedule for you.`);
    twiml.redirect('/appt-find-slots');
    return res.type('text/xml').send(twiml.toString());
  }
  res.type('text/xml').send(twiml.toString());
});

// ═══════════════════════════════════════════════════════════════════════════════
// ROUTE — Confirm or update contact info for existing patient
// ═══════════════════════════════════════════════════════════════════════════════
app.post('/appt-confirm-contact', (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);

  const wantsUpdate = /no|update|change|different|wrong|incorrect|new|moved|changed/.test(speech);
  const confirmed = /yes|correct|right|good|same|that's right|yep|yeah/.test(speech);

  if (wantsUpdate || (!confirmed && speech.length > 0)) {
    // Ask what they want to update
    const g = gather(twiml, '/appt-update-contact-field', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, `No problem! What would you like to update — your phone number, email, or address?`);
  } else if (!sess.addressOnFile) {
    // No address on file — collect it now
    sess.collectedPhone = sess.phoneOnFile;
    const g = gather(twiml, '/appt-collect-existing-address', { input: 'speech', speechTimeout: '2', timeout: 15 });
    say(g, `${pick(AFFIRMATIONS)} I don't have an address on file for you yet — could you give me your current home address, including street, city, state, and zip code?`);
  } else {
    // Contact info confirmed — skip PIN (A2P pending approval) and proceed to scheduling
    sess.collectedPhone = sess.phoneOnFile;
    sess.contactInfoConfirmed = true; // Any subsequent request this call skips re-collection
    say(twiml, `Perfect! Let me pull up our available times for you.`);
    twiml.redirect('/appt-find-slots');
  }
  res.type('text/xml').send(twiml.toString());
});

// ═══════════════════════════════════════════════════════════════════════════════
// ROUTE — Collect address for existing patient who has no address on file
// ═══════════════════════════════════════════════════════════════════════════════
app.post('/appt-collect-existing-address', (req, res) => {
  const speech = (req.body.SpeechResult || '').trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  if (!speech) {
    const g = gather(twiml, '/appt-collect-existing-address', { input: 'speech', speechTimeout: '2', timeout: 15 });
    say(g, pick(RETRY_PROMPTS) + ' What is your full home address, including street, city, state, and zip code?');
    return res.type('text/xml').send(twiml.toString());
  }
  sess._pendingAddress = speech;
  const g = gather(twiml, '/appt-confirm-existing-address', { input: 'speech', speechTimeout: '3', timeout: 12 });
  say(g, `I have your address as ${speech} — is that correct?`);
  res.type('text/xml').send(twiml.toString());
});

app.post('/appt-confirm-existing-address', async (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase().trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  const confirmed = /yes|correct|right|good|that.?s right|yep|yeah|uh.?huh/.test(speech);
  if (!confirmed) {
    const g = gather(twiml, '/appt-collect-existing-address', { input: 'speech', speechTimeout: '2', timeout: 15 });
    say(g, 'No problem! Let me get your address again — please give me your full address including street, city, state, and zip.');
    return res.type('text/xml').send(twiml.toString());
  }
  sess.address = sess._pendingAddress;
  delete sess._pendingAddress;
  // Save address to IntakeQ
  if (sess.existingClientId) {
    await updatePatientContact(sess.existingClientId, { Address: sess.address }).catch(() => {});
  }
  sess.contactInfoConfirmed = true;
  say(twiml, `${pick(AFFIRMATIONS)} I've updated your address. Let me pull up our available times for you.`);
  twiml.redirect('/appt-find-slots');
  res.type('text/xml').send(twiml.toString());
});

// ═══════════════════════════════════════════════════════════════════════════════
// ROUTE — Determine which contact field to update
// ═══════════════════════════════════════════════════════════════════════════════
app.post('/appt-update-contact-field', (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);

  if (/phone|number|cell|mobile/.test(speech)) {
    sess.updatingField = 'phone';
    const g = gather(twiml, '/appt-save-contact-update', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, `What is your new phone number?`);
  } else if (/email|e-mail/.test(speech)) {
    sess.updatingField = 'email';
    const g = gather(twiml, '/appt-save-contact-update', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, `What is your new email address?`);
  } else if (/address|street|moved|location/.test(speech)) {
    sess.updatingField = 'address';
    const g = gather(twiml, '/appt-save-contact-update', { input: 'speech', speechTimeout: '2', timeout: 15 });
    say(g, `What is your new home address?`);
  } else {
    const g = gather(twiml, '/appt-update-contact-field', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, `I didn't catch that. Would you like to update your phone number, email, or address?`);
  }
  res.type('text/xml').send(twiml.toString());
});

// ═══════════════════════════════════════════════════════════════════════════════
// ROUTE — Save the updated contact field to IntakeQ
// ═══════════════════════════════════════════════════════════════════════════════
app.post('/appt-save-contact-update', async (req, res) => {
  const speech = (req.body.SpeechResult || '').trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);

  if (!speech) {
    const g = gather(twiml, '/appt-save-contact-update', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, `I didn't catch that. Please say it again.`);
    return res.type('text/xml').send(twiml.toString());
  }

  try {
    const clientId = sess.existingClientId;
    let updatePayload = {};
    if (sess.updatingField === 'phone') {
      updatePayload = { Phone: speech, CellPhone: speech };
      sess.collectedPhone = speech; // Use new phone for PIN delivery
    } else if (sess.updatingField === 'email') {
      updatePayload = { Email: speech };
    } else if (sess.updatingField === 'address') {
      updatePayload = { Address: speech };
    }
    await updatePatientContact(clientId, updatePayload).catch(() => {});
    say(twiml, `Got it — I've updated your ${sess.updatingField} in our system.`);
  } catch (err) {
    console.error('[UPDATE CONTACT]', err.message);
    say(twiml, `I had a little trouble saving that, but I've noted it for our team.`);
    escalateToStaff(sess.callerPhone, `Patient contact update needed`, `Patient: ${sess.firstName} ${sess.lastName} | Update: ${sess.updatingField} → ${speech}`).catch(() => {});
  }

  // Ask if they want to update anything else
  const g = gather(twiml, '/appt-more-updates', { input: 'speech', speechTimeout: '2', timeout: 10 });
  say(g, `Is there anything else you'd like to update?`);
  res.type('text/xml').send(twiml.toString());
});

// ═══════════════════════════════════════════════════════════════════════════════
// ROUTE — Ask if more updates needed, then proceed to scheduling (PIN bypassed — A2P pending)
// ═══════════════════════════════════════════════════════════════════════════════
app.post('/appt-more-updates', (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);

  if (/yes|yeah|yep|also|and|another/.test(speech)) {
    const g = gather(twiml, '/appt-update-contact-field', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, `Of course! What else would you like to update — phone, email, or address?`);
  } else {
    // Skip PIN (A2P pending approval) — go directly to scheduling
    sess.contactInfoConfirmed = true;
    say(twiml, `Great, you're all set! Let me pull up our available times for you.`);
    twiml.redirect('/appt-find-slots');
  }
  res.type('text/xml').send(twiml.toString());
});

// ═══════════════════════════════════════════════════════════════════════════════
// ROUTE — Send PIN to patient (issue new or resend existing)
// ═══════════════════════════════════════════════════════════════════════════════
app.post('/appt-send-pin', async (req, res) => {
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  try {
    const client = sess.existingClient;
    const clientId = sess.existingClientId;
    const existingPin = client ? extractPin(client.AdditionalInformation) : null;
    let pin = existingPin;

    if (!pin) {
      pin = generatePin();
      await storePinForClient(clientId, pin, client ? client.AdditionalInformation : '').catch(() => {});
    }
    sess.expectedPin = pin;

    // Send to updated phone (or caller ID if no update)
    const smsTarget = sess.collectedPhone || sess.callerPhone;
    const isNew = !existingPin;
    const pinMsg = isNew
      ? `Taylor Medical Group — Your Security PIN\n\nYour new PIN is: ${pin}\n\nPlease save this — you'll use it every time you call to verify your identity.\n\nPatient portal: ${CONFIG.intakeq.portalUrl}`
      : `Taylor Medical Group — Your Security PIN\n\nYour PIN is: ${pin}\n\nUse this to verify your identity on future calls.\n\nPatient portal: ${CONFIG.intakeq.portalUrl}`;
    await sendSms(smsTarget, pinMsg).catch(() => {});

    // Also email the PIN to the patient's email on file (SMS fallback during A2P pending)
    const patientEmail = client ? client.Email : null;
    if (patientEmail) {
      const pinHtml = `
        <div style="font-family: Arial, sans-serif; max-width: 500px; margin: 0 auto;">
          <h2 style="color: #2c5282;">Taylor Medical Group — Your Security PIN</h2>
          <p>Hello ${sess.firstName || 'Patient'},</p>
          <p>${isNew ? 'We have created a security PIN for your account.' : 'Here is your security PIN for your account.'}</p>
          <div style="background: #f0f4ff; border: 2px solid #2c5282; border-radius: 8px; padding: 20px; text-align: center; margin: 20px 0;">
            <p style="font-size: 36px; font-weight: bold; letter-spacing: 8px; color: #2c5282; margin: 0;">${pin}</p>
            <p style="color: #718096; font-size: 13px; margin: 8px 0 0;">Your 4-digit security PIN</p>
          </div>
          <p>Please save this PIN — you will use it to verify your identity when you call us.</p>
          <p>You can also access your patient portal at: <a href="${CONFIG.intakeq.portalUrl}">${CONFIG.intakeq.portalUrl}</a></p>
          <p style="color: #718096; font-size: 12px; margin-top: 20px;">Taylor Medical Group | 678-443-4000</p>
        </div>
      `;
      await axios.post('https://api.resend.com/emails', {
        from: CONFIG.email.fromAddress,
        to: [patientEmail],
        subject: `Taylor Medical Group — Your Security PIN`,
        html: pinHtml,
        text: pinMsg,
      }, { headers: { 'Authorization': `Bearer ${CONFIG.email.resendApiKey}`, 'Content-Type': 'application/json' }, timeout: 8000 }).catch(e => console.error('[PIN EMAIL]', e.message));
    }

    const g = gather(twiml, '/appt-pin-verify', { input: 'speech dtmf', speechTimeout: '2', timeout: 60 });
    say(g, isNew
      ? `I've created a 4-digit security PIN for your account and I'm sending it to you by both text and email right now. Please check your phone or email and tell me your PIN whenever you're ready — you have about 60 seconds.`
      : `I've just sent your security PIN to the phone number and email address we have on file. Please check your text messages or email and say or enter your 4-digit PIN to continue — you have about 60 seconds.`);
   } catch (err) {
    console.error('[SEND PIN]', err.message);
    say(twiml, `I had a little trouble with your account right now. Let me go ahead and pull up our schedule for you.`);
    twiml.redirect('/appt-find-slots');
    return res.type('text/xml').send(twiml.toString());
  }
  res.type('text/xml').send(twiml.toString());
});
// ═══════════════════════════════════════════════════════════════════════════════
// ROUTE — Verify PIN entry for existing patient
// ═══════════════════════════════════════════════════════════════════════════════
app.post('/appt-pin-verify', (req, res) => {
  const callSid = req.body.CallSid;
  const rawSpeech = (req.body.SpeechResult || '').toLowerCase().trim();
  const speech = rawSpeech.replace(/\D/g, '');
  const digits = (req.body.Digits || '').trim();
  const entered = digits || speech;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  const expected = sess.expectedPin;

  // Detect "can't receive / didn't get it" — send to portal
  const cantReceive = /can.t|cannot|didn.t|did not|don.t|do not|not get|not receive|never got|never received|no email|no pin|haven.t|haven't|haven't|not getting|not coming|won.t|won't/.test(rawSpeech);
  if (cantReceive) {
    const patientEmail = sess.patientRecord?.Email || null;
    if (patientEmail) {
      sendPortalLinkToPatient(patientEmail, `${sess.firstName || ''} ${sess.lastName || ''}`.trim()).catch(() => {});
    }
    escalateToStaff(sess.callerPhone, 'PIN not received — patient directed to portal', `Patient: ${sess.firstName || ''} ${sess.lastName || ''} | Phone: ${sess.collectedPhone || sess.callerPhone}`).catch(() => {});
    say(twiml, `No problem at all! I've just sent the patient portal link to your phone and email right now — please check your inbox and look for an email from us. You can also visit Taylor Medical Group dot net directly and click Patient Portal in the top right corner. The portal allows you to communicate directly with our doctors, book appointments, view your invoices, and see your prescription history. Please note that we do not accept emails from patients — all requests must go through the patient portal.`);
    const g = gather(twiml, '/main-intent', { input: 'speech', speechTimeout: '2', timeout: 10 });
    say(g, 'Is there anything else I can help you with today?');
    twiml.hangup();
    return res.type('text/xml').send(twiml.toString());
  }

  if (!entered) {
    const g = gather(twiml, '/appt-pin-verify', { input: 'speech dtmf', speechTimeout: '2', timeout: 20 });
    say(g, "I didn't catch that. Please say or enter your 4-digit PIN, or let me know if you didn't receive it.");
    return res.type('text/xml').send(twiml.toString());
  }

  if (entered === expected) {
    // Read back contact info and ask if it needs updating before scheduling
    const phoneOnFile = (sess.patientRecord && sess.patientRecord.Phone) ? sess.patientRecord.Phone : null;
    const emailOnFile = (sess.patientRecord && sess.patientRecord.Email) ? sess.patientRecord.Email : null;
    sess.contactVerified = false;
    const g = gather(twiml, '/appt-verify-contact', { input: 'speech', speechTimeout: '2', timeout: 12 });
    if (phoneOnFile || emailOnFile) {
      let infoStr = '';
      if (phoneOnFile) infoStr += `phone as ${phoneOnFile}`;
       if (phoneOnFile && emailOnFile) infoStr += ', and ';
      if (emailOnFile) infoStr += `email as ${spellOutEmail(emailOnFile)}`;
      say(g, `Perfect — I've verified your identity. Welcome back, ${sess.pronouncedName || sess.firstName}! I have your ${infoStr} on file. Is all of that still correct, or would you like to update anything?`);
    } else {
      say(g, `Perfect — I've verified your identity. Welcome back, ${sess.pronouncedName || sess.firstName}! I don't have a phone or email on file for you. Would you like to update your contact information before we continue?`);
    }
  } else {
    sess.pinAttempts = (sess.pinAttempts || 0) + 1;
    if (sess.pinAttempts >= 2) {
      const patientEmail = sess.patientRecord?.Email || null;
      if (patientEmail) {
        sendPortalLinkToPatient(patientEmail, `${sess.firstName || ''} ${sess.lastName || ''}`.trim()).catch(() => {});
      }
      escalateToStaff(sess.callerPhone, 'PIN verification failed — patient needs follow-up', `Patient: ${sess.firstName || ''} ${sess.lastName || ''} | DOB: ${sess.dob || ''} | Phone: ${sess.collectedPhone || sess.callerPhone}`).catch(() => {});
      say(twiml, `I'm sorry, that PIN doesn't match what we have on file. For your security, I've sent a portal link to your email on file. The patient portal allows you to communicate directly with our doctors, view your invoices, book appointments, and see your prescription history. Please visit Taylor Medical Group dot net and click Patient Portal in the top right corner. Our team will also follow up with you personally.`);
      twiml.hangup();
    } else {
      const g = gather(twiml, '/appt-pin-verify', { input: 'speech dtmf', speechTimeout: '2', timeout: 20 });
      say(g, "That PIN doesn't match. Please check your email and try again.");
    }
  }
  res.type('text/xml').send(twiml.toString());
});

