});

app.post('/lead-confirm-email', (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase().trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  const confirmed = /yes|correct|right|good|that.?s right|yep|yeah|uh.?huh/.test(speech);
  if (!confirmed) {
    // Re-spell
    const g = gather(twiml, '/lead-spell-email', { input: 'speech', speechTimeout: '4', timeout: 20 });
    say(g, "No problem! Let's try again — please spell your email address one letter at a time, saying at for the at sign and dot for the period.");
    return res.type('text/xml').send(twiml.toString());
  }
  sess.email = sess._pendingEmail;
  delete sess._pendingEmail;
  const g = gather(twiml, '/lead-collect-callback', { input: 'speech', speechTimeout: '2', timeout: 12 });
  say(g, `${pick(AFFIRMATIONS)} And what is the best callback number for you?`);
  res.type('text/xml').send(twiml.toString());
});

app.post('/lead-collect-callback', async (req, res) => {
  const speech = (req.body.SpeechResult || '').trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  if (!speech) {
    const g = gather(twiml, '/lead-collect-callback', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, "I didn't catch that. What is your callback number?");
    return res.type('text/xml').send(twiml.toString());
  }
  sess.collectedPhone = speech;
  // Save lead to IntakeQ immediately
  try {
    const cleanPhone = (sess.collectedPhone || sess.callerPhone).replace(/\D/g, '').slice(-10);
    const clientData = { FirstName: sess.firstName, LastName: sess.lastName || 'Unknown', Phone: cleanPhone };
    if (sess.email) clientData.Email = sess.email;
    const newClient = await intakeqRequest('POST', '/clients', clientData);
    sess.leadClientId = newClient ? (newClient.ClientId || newClient.Id) : null;
  } catch (e) { console.error('[LEAD SAVE]', e.message); }
  // Notify staff of new lead
  escalateToStaff(sess.callerPhone, '🆕 New Patient Lead Captured', `Name: ${sess.firstName} ${sess.lastName || ''}\nEmail: ${sess.email || 'not given'}\nCallback: ${sess.collectedPhone}\nCaller ID: ${sess.callerPhone}`).catch(() => {});
  // Ask if they want service info or book now
  const g = gather(twiml, '/lead-next-step', { input: 'speech', speechTimeout: '2', timeout: 14 });
  say(g, `Wonderful, ${sess.pronouncedName || sess.firstName}! You are all set — we are so excited to have you! Now, would you like to hear about our services, or are you ready to go ahead and schedule your appointment today?`);
  res.type('text/xml').send(twiml.toString());
});

app.post('/lead-next-step', (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase().trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);

  const wantsInfo = /info|information|learn|tell me|what do you|services|offer|what services|what do you offer|what do you treat|what do you do|what can you|what are your|more about|curious|interested in|hear about/.test(speech);
  const wantsBook = /book|schedule|yes|now|today|appointment|go ahead|let.s do|sure|ready|schedule now/.test(speech);

  if (wantsBook) {
    const g = gather(twiml, '/appt-service-type', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, "Wonderful! What brings you in — are you interested in hormone therapy, weight loss, IV therapy, telehealth, or something else?");
  } else {
    // Default to services info if unclear or they ask about services
    const g = gather(twiml, '/lead-service-interest', { input: 'speech', speechTimeout: '2', timeout: 14 });
    say(g, "Of course! We specialize in hormone therapy and balance, weight loss and metabolic health, IV therapy, functional medicine, cosmetic treatments, and telehealth. Which of those areas would you like to know more about?");
  }
  res.type('text/xml').send(twiml.toString());
});

app.post('/lead-service-interest', (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase().trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  let info = '';

  if (/hormone|bhrt|estrogen|progesterone|testosterone|menopause|perimenopause|thyroid|adrenal|pcos|hot flash|night sweat|low libido|sex drive|mood|fatigue|brain fog/.test(speech)) {
    info = "Our hormone therapy program is one of our most popular services. We use saliva testing to get a precise picture of your hormone levels — not just blood work — and we create a fully customized bioidentical hormone plan for you. We treat estrogen and progesterone imbalance, testosterone deficiency, thyroid issues, adrenal fatigue, and more. Many patients feel a significant difference within the first few weeks.";
  } else if (/weight|metabolic|semaglutide|ozempic|tirzepatide|mounjaro|glp|insulin|diabetes|obesity/.test(speech)) {
    info = "Our weight loss and metabolic health program combines GLP-1 medications like semaglutide and tirzepatide with a functional medicine approach to address the root causes of weight gain — including hormone imbalance, insulin resistance, and inflammation. We don't just prescribe a medication and send you home. Our doctors work with you on a complete metabolic reset.";
  } else if (/iv|infusion|drip|chelation|nad|vitamin c|glutathione|myers|iron|ozone|hydrogen peroxide/.test(speech)) {
    info = "We offer a full menu of IV therapies, all personally administered by our doctors. Options include the Myers Cocktail, NAD plus, high-dose Vitamin C, Glutathione, Iron Infusions, Chelation therapy, Ozone IV, and more. All new IV patients require a brief evaluation first, which can often be done the same day as your first treatment.";
  } else if (/cosmetic|botox|filler|microneedling|prp|o.shot|p.shot|skin|laser|liposuction|strawberry|exosome/.test(speech)) {
    info = "Our cosmetic services include Botox, dermal fillers, microneedling with PRP, the O-Shot and P-Shot for sexual wellness, Strawberry laser lipo, and skin rejuvenation treatments. Our doctors personally perform all cosmetic procedures.";
  } else if (/telehealth|virtual|video|phone visit|remote/.test(speech)) {
    info = "We offer telehealth appointments for both new and established patients. You can book online 24 hours a day, 7 days a week. It's a great way to get started from the comfort of your home. Visit our booking link to see current pricing and available times.";
  } else {
    info = "We offer hormone therapy, weight loss and metabolic health, IV therapy, functional medicine, cosmetic treatments, and telehealth. Our doctors take a root-cause approach — we don't just treat symptoms, we look for what's driving them. Most patients come to us after feeling dismissed or unheard elsewhere.";
  }

  sendCallSummaryToStaff(sess.callerPhone, `New Patient Lead — Service Interest\nName: ${sess.firstName} ${sess.lastName || ''}\nInterest: ${speech}\nEmail: ${sess.email || 'not given'}\nCallback: ${sess.collectedPhone || sess.callerPhone}`).catch(() => {});

  say(twiml, `${info}`);
  const g = gather(twiml, '/lead-next-step', { input: 'speech', speechTimeout: '2', timeout: 12 });
  say(g, "Would you like to schedule a consultation today, or is there anything else I can help you with?");
  res.type('text/xml').send(twiml.toString());
});

app.post('/appt-service-type', (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  const isNew = sess.patientType === 'new';
  let selected;

  if (isNew) {
    if (/hormone|wellness|bhrt|testosterone|menopause|thyroid|adrenal|pcos|weight|semaglutide|ozempic|tirzepatide|glp/.test(speech)) {
      selected = { id: CONFIG.services.newPatientHormone30, name: 'a New Patient Wellness and Hormone consultation', price: '$175', duration: '30 minutes' };
    } else if (/60|hour|long|comprehensive/.test(speech)) {
      selected = { id: CONFIG.services.newPatientHormone60, name: 'a New Patient 60-minute consultation', price: '$300', duration: '60 minutes' };
    } else if (/iv|infusion|drip|chelation|ozone|vitamin c|glutathione|nad|ketamine|magnesium|myers|hydration/.test(speech)) {
      selected = { id: CONFIG.services.newPatientIVConsult, name: 'a New Patient IV Therapy consultation', price: '$175', duration: '30 minutes' };
    } else if (/telehealth|virtual|phone|video|zoom/.test(speech)) {
      selected = { id: CONFIG.services.newPatientTelehealth30, name: 'a New Patient Telehealth visit', price: '$175', duration: '30 minutes' };
    } else {
      selected = { id: CONFIG.services.newPatientHormone30, name: 'a New Patient consultation', price: '$175', duration: '30 minutes' };
    }
  } else {
    if (/annual|yearly|wellness/.test(speech)) {
      selected = { id: CONFIG.services.establishedAnnual30, name: 'an Annual Wellness visit', price: '$475', duration: '30 minutes' };
    } else if (/telehealth|virtual|phone|video|zoom/.test(speech)) {
      selected = { id: CONFIG.services.establishedTelehealth30, name: 'a Telehealth visit', price: '$150', duration: '30 minutes' };
    } else if (/iv|infusion|drip/.test(speech)) {
      selected = { id: CONFIG.services.newPatientIVConsult, name: 'an IV Therapy consultation', price: '$175', duration: '30 minutes' };
    } else {
      selected = { id: CONFIG.services.establishedFollowUp30, name: 'a Follow-up visit', price: '$150', duration: '30 minutes' };
    }
  }

  sess.serviceId = selected.id;
  sess.serviceName = selected.name;
  sess.servicePrice = selected.price;
  sess.serviceDuration = selected.duration;
  // Auto-assign Dr. Ava for vaginal rejuvenation
  if (/vaginal|rejuvenation/i.test(selected.name)) {
    sess.practitionerId = CONFIG.intakeq.practitioners.ava.id;
    sess.practitionerName = CONFIG.intakeq.practitioners.ava.name;
    say(twiml, `Perfect! I'll get you scheduled for ${selected.name} with ${CONFIG.intakeq.practitioners.ava.name}. We don't accept insurance, but we do accept HSA and FSA cards.`);
    if (sess.firstName && sess.lastName) {
      const g = gather(twiml, '/appt-collect-dob', { input: 'speech', speechTimeout: '2', timeout: 12 });
      say(g, `For verification, ${sess.firstName}, what is your date of birth?`);
    } else {
      const g = gather(twiml, '/appt-collect-name', { input: 'speech', speechTimeout: '2', timeout: 10 });
      say(g, 'Could you please tell me your first name?');
    }
  } else {
    say(twiml, `Perfect! I'll get you scheduled for ${selected.name}. We don't accept insurance, but we do accept HSA and FSA cards.`);
    const g = gather(twiml, '/appt-select-doctor', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, 'Would you like to schedule with Dr. Eldred Taylor or Dr. Ava Bell-Taylor?');
  }
  res.type('text/xml').send(twiml.toString());
});

