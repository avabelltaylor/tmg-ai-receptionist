}

// ─── Voicemail email notification ─────────────────────────────────────────────
async function sendVoicemailToStaff(callerPhone, transcription, recordingUrl) {
  const now = new Date().toLocaleString('en-US', { timeZone: 'America/New_York' });
  // Convert raw Twilio recording URL to our proxy URL so staff can listen without logging in
  let proxyUrl = null;
  if (recordingUrl) {
    const sidMatch = recordingUrl.match(/Recordings\/(RE[a-z0-9]+)/i);
    if (sidMatch) {
      proxyUrl = `https://tmg-ai-receptionist-production.up.railway.app/recording/${sidMatch[1]}`;
    } else {
      proxyUrl = recordingUrl; // fallback to original
    }
  }
  const msg = `📨 TMG Voicemail — ${now} ET\n📱 Caller: ${callerPhone}\n─────────────────────\nMessage: ${transcription || '(No transcription available)'}\n\n🎧 Listen: ${proxyUrl || 'N/A'}`;

  // SMS
  for (const num of CONFIG.escalation.smsNumbers) await sendSms(num, msg).catch(() => {});

  // Email
  const htmlBody = `
    <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
      <h2 style="color: #2c5282; border-bottom: 2px solid #2c5282; padding-bottom: 8px;">
        📨 TMG Voicemail Message
      </h2>
      <p><strong>Time:</strong> ${now} ET</p>
      <p><strong>Caller:</strong> ${callerPhone}</p>
      <hr style="border: 1px solid #e2e8f0;" />
      <div style="background: #f7fafc; padding: 16px; border-radius: 8px; font-size: 14px;">
        <p><strong>Message Transcription:</strong></p>
        <p style="font-style: italic;">${transcription || '(Transcription not available — please listen to recording)'}</p>
      </div>
      ${proxyUrl ? `
      <p style="margin-top: 16px;">
        <a href="${proxyUrl}" style="background: #2c5282; color: white; padding: 10px 20px; border-radius: 6px; text-decoration: none; display: inline-block;">
          🎧 Listen to Recording
        </a>
        <br/><small style="color:#718096;font-size:11px;">Click to play — no login required</small>
      </p>` : ''}
      <p style="color: #718096; font-size: 12px; margin-top: 16px;">
        Sent by Taylor AI Receptionist — Taylor Medical Group
      </p>
    </div>
  `;
  await sendEmail(
    `📨 TMG Voicemail — ${callerPhone} — ${now} ET`,
    htmlBody,
    msg
  ).catch(() => {});
}

