// Step 5: Create full IntakeQ patient record with all collected demographics
app.post('/appt-new-create-record', async (req, res) => {
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  try {
    const cleanPhone = (sess.collectedPhone || sess.callerPhone || '').replace(/\D/g, '').slice(-10);
    // Build DOB as Unix ms timestamp if parseable, otherwise omit
    let dobMs = null;
    if (sess.dob) {
      const parsed = new Date(sess.dob);
      if (!isNaN(parsed.getTime())) dobMs = parsed.getTime();
    }
    const clientData = {
      FirstName: sess.firstName || 'Patient',
      LastName: sess.lastName || 'Unknown',
      Phone: cleanPhone,
      MobilePhone: cleanPhone,
    };
    if (sess.email) clientData.Email = sess.email;
    if (dobMs) clientData.DateOfBirth = dobMs;
    if (sess.address) clientData.Address = sess.address;
    if (sess.gender) clientData.Gender = sess.gender;
    clientData.BillingType = 1; // Self-pay only — practice does not accept insurance
    if (sess.emergencyContactName) clientData.EmergencyContactName = sess.emergencyContactName;
    if (sess.emergencyContactPhone) clientData.EmergencyContactPhone = sess.emergencyContactPhone;
    const newClient = await intakeqRequest('POST', '/clients', clientData);
    if (newClient && (newClient.ClientId || newClient.Id)) {
      sess.newPatientClientId = newClient.ClientId || newClient.Id;
      sess.existingClientId = sess.newPatientClientId; // used by booking route
      console.log(`[NEW PATIENT RECORD] Created IntakeQ client ID: ${sess.newPatientClientId} for ${sess.firstName} ${sess.lastName}`);
    } else {
      console.warn('[NEW PATIENT RECORD] IntakeQ creation returned no ID — will create at booking time');
    }
  } catch (err) {
    console.error('[NEW PATIENT RECORD]', err.message);
    // Non-fatal — findOrCreateClient at booking time will handle it
  }
  sess.contactInfoConfirmed = true;
  say(twiml, `${pick(AFFIRMATIONS)} I have everything I need. Let me check our available appointment times for you — just one moment.`);
  twiml.redirect('/appt-find-slots');
  res.type('text/xml').send(twiml.toString());
});

// ═══════════════════════════════════════════════════════════════════════════════════════════════════════
// LEGACY — appt-collect-address (kept for any legacy paths that redirect here)
// ═══════════════════════════════════════════════════════════════════════════════════════════════════════

app.post('/appt-collect-address', (req, res) => {
  const speech = (req.body.SpeechResult || '').trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  if (!speech) {
    const g = gather(twiml, '/appt-collect-address', { input: 'speech', speechTimeout: '2', timeout: 15 });
    say(g, pick(RETRY_PROMPTS) + ' What is your full home address, including street, city, state, and zip code?');
    return res.type('text/xml').send(twiml.toString());
  }
  // Escape hatch
  const esc = checkEscape(speech, sess, { noPivot: true });
  if (esc.action === 'correct') {
    const g = gather(twiml, '/appt-collect-phone', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, "No problem! Let me get your phone number again — what is it?");
    return res.type('text/xml').send(twiml.toString());
  }
  if (esc.action === 'exit') {
    say(twiml, "Of course! Have a wonderful day — don't hesitate to call us if you need anything!");
    twiml.hangup();
    return res.type('text/xml').send(twiml.toString());
  }
  if (esc.action === 'pivot') {
    twiml.redirect('/main-intent');
    return res.type('text/xml').send(twiml.toString());
  }
  // Read back address for confirmation
  sess._pendingAddress = speech;
  const g = gather(twiml, '/appt-confirm-address', { input: 'speech', speechTimeout: '3', timeout: 12 });
  say(g, `I have your address as ${speech} — is that correct?`);
  res.type('text/xml').send(twiml.toString());
});

app.post('/appt-confirm-address', async (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase().trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  const confirmed = /yes|correct|right|good|that.?s right|yep|yeah|uh.?huh/.test(speech);
  if (!confirmed) {
    const g = gather(twiml, '/appt-collect-address', { input: 'speech', speechTimeout: '2', timeout: 15 });
    say(g, "No problem! Let me get your address again — please give me your full address including street, city, state, and zip.");
    return res.type('text/xml').send(twiml.toString());
  }
  sess.address = sess._pendingAddress;
  delete sess._pendingAddress;
  // For new patients: check if email is collected — if not, collect it now before scheduling
  if (sess.patientType === 'new' && !sess.email) {
    twiml.redirect('/lead-collect-email');
    return res.type('text/xml').send(twiml.toString());
  }
  sess.contactInfoConfirmed = true;
  say(twiml, `${pick(AFFIRMATIONS)} Let me check our available appointment times for you — just one moment.`);
  twiml.redirect('/appt-find-slots');
  res.type('text/xml').send(twiml.toString());
});

app.post('/appt-find-slots', async (req, res) => {
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  try {
    // Use default service ID if none was set (fallback to established follow-up)
    const serviceId = sess.serviceId || CONFIG.services.establishedFollowUp30;
    const slots = await findOpenSlots(serviceId, 21);
    sess.slots = slots;
    if (!slots || slots.length === 0) {
    say(twiml, "I'm not seeing any open slots in our system right now. Please visit Taylor Medical Group dot net and click Patient Portal in the top right corner to see the full calendar and book directly.");
      twiml.hangup();
      return res.type('text/xml').send(twiml.toString());
    }
    const offered = slots.slice(0, 3);
    sess.offeredSlots = offered;
    let slotScript = `I found some great options for you! `;
    offered.forEach((slot, i) => { slotScript += `Option ${i + 1} is ${slot.label}. `; });
    slotScript += `If none of those work for you, just say sooner and I'll reach out to the office. Otherwise, just tell me which option you'd like.`;
    const g = gather(twiml, '/appt-select-slot', { input: 'speech dtmf', speechTimeout: '2', timeout: 12 });
    say(g, slotScript);
  } catch (err) {
    console.error('[SLOTS]', err.message);
    say(twiml, "I'm having a little trouble with our scheduling system right now. Please visit Taylor Medical Group dot net and click Patient Portal in the top right corner to book online.");
    sendSms(sess.callerPhone, `Taylor Medical Group — Book an Appointment:\n${CONFIG.intakeq.bookingUrl}`).catch(() => {});
    twiml.hangup();
    return res.type('text/xml').send(twiml.toString());
  }
  res.type('text/xml').send(twiml.toString());
});

app.post('/appt-select-slot', (req, res) => {
  const digit = (req.body.Digits || '').trim();
  const speech = (req.body.SpeechResult || '').toLowerCase();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  const wantsSooner = digit === '4' || /soon|earlier|sooner|before|faster|urgent|this week|next week/.test(speech);
  if (wantsSooner) {
    const g = gather(twiml, '/appt-sooner-date', { input: 'speech', speechTimeout: '2', timeout: 12 });
    say(g, "Of course! What date and time works best for you?");
    return res.type('text/xml').send(twiml.toString());
  }
  let slotIndex = -1;
  if (digit === '1' || /option 1|first|one/.test(speech)) slotIndex = 0;
  else if (digit === '2' || /option 2|second|two/.test(speech)) slotIndex = 1;
  else if (digit === '3' || /option 3|third|three/.test(speech)) slotIndex = 2;
  if (slotIndex === -1 || !sess.offeredSlots || !sess.offeredSlots[slotIndex]) {
    const g = gather(twiml, '/appt-select-slot', { input: 'speech dtmf', speechTimeout: '2', timeout: 10 });
    say(g, "Just say option 1, 2, or 3 to choose your time, or say sooner if you need an earlier appointment.");
    return res.type('text/xml').send(twiml.toString());
  }
  sess.selectedSlot = sess.offeredSlots[slotIndex];
  say(twiml, `Wonderful! You've chosen ${sess.selectedSlot.label}. Let me get that booked for you right now — just one moment.`);
  twiml.redirect('/appt-confirm-booking');
  res.type('text/xml').send(twiml.toString());
});

app.post('/appt-sooner-date', async (req, res) => {
  const speech = (req.body.SpeechResult || '').trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  const preferredTime = speech || 'as soon as possible';
  await escalateToStaff(sess.callerPhone, 'Patient requesting earlier appointment', `Patient: ${sess.firstName || ''} ${sess.lastName || ''} | Service: ${sess.serviceName || ''} | Preferred: ${preferredTime}`).catch(() => {});
  await sendSms(sess.callerPhone, `Taylor Medical Group — Earlier Appointment Request\n\nYour request for ${preferredTime} has been sent to our office.\n\nThe team will reach out through the patient portal:\n${CONFIG.intakeq.portalUrl}\n\nPlease log in so we can confirm your appointment.\n\nQuestions? Call 678-443-4000`).catch(() => {});
  say(twiml, `Perfect! I've sent your request for ${preferredTime} to our office right now. The team will reach out to you through the patient portal with your appointment options. Please visit Taylor Medical Group dot net and click Patient Portal in the top right corner to log in so our team can reach you.`);
  sendCallSummaryToStaff(sess.callerPhone, `Reason: Earlier appointment request\nPatient: ${sess.firstName || ''} ${sess.lastName || ''}\nService: ${sess.serviceName || ''}\nPreferred: ${preferredTime}`).catch(() => {});
  const g = gather(twiml, '/main-intent', { timeout: 8 }); say(g, "Is there anything else I can do for you today?"); twiml.hangup();
  res.type('text/xml').send(twiml.toString());
});

app.post('/appt-confirm-booking', async (req, res) => {
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  try {
    const safePhone = (sess.collectedPhone || sess.phoneOnFile || sess.callerPhone || '').replace(/\D/g, '').slice(-10) || '0000000000';
    const result = await findOrCreateClient(sess.firstName || 'Patient', sess.lastName || 'Unknown', safePhone, sess.dob, sess.address);
    const clientId = result.id;
    const client = result.client;
    if (!clientId) throw new Error('Could not create or find client in IntakeQ');
    const existingPin = client ? extractPin(client.AdditionalInformation) : null;
    let patientPin = existingPin;
    if (!existingPin) {
      patientPin = generatePin();
      await storePinForClient(clientId, patientPin, client ? client.AdditionalInformation : '').catch(() => {});
    }
    const appt = await bookAppointment(clientId, sess.serviceId, sess.selectedSlot.utcMs, sess.practitionerId);
    if (!appt || !appt.Id) throw new Error('Appointment creation failed');
    // Detect visit type for forms warning
    const isTelehealth = /telehealth|virtual|video|phone visit/i.test(sess.serviceName || '');
    const isNewPatient = result.isNew || sess.patientType === 'new';
    const isAnnual = /annual|yearly|wellness/i.test(sess.serviceName || '') || sess.serviceId === CONFIG.services.establishedAnnual30;
    const requiresForms = isNewPatient || isAnnual || isTelehealth;

    let confirmSms = `✅ Taylor Medical Group — Appointment Confirmed!\n\nPatient: ${sess.firstName} ${sess.lastName}\nService: ${sess.serviceName}\nDate: ${sess.selectedSlot.label}\n\n`;
    if (!isTelehealth) {
      confirmSms += `📍 5901 Peachtree Dunwoody Rd, Bldg C, Suite C25\nSandy Springs, GA 30328\n\n🅿️ Park in the Building C deck, take elevator to level T (tunnel). First suite on your left.\n\n`;
    }
    if (!existingPin) confirmSms += `🔐 Your Security PIN: ${patientPin}\nSave this for future calls to verify your identity.\n\n`;

    if (requiresForms) {
      // New patient, annual visit, or telehealth: forms sent automatically via portal
      confirmSms += `📋 Your patient forms have been automatically sent to your email via the patient portal. Please complete and submit them at least 24 business hours before your appointment.\n\n⚠️ IMPORTANT: If forms are not received at least 24 business hours before your appointment, your appointment will be cancelled and you will need to reschedule.\n\nQuestions? Call 678-443-4000`;
    } else {
      // Established patient standard follow-up: standard confirmation
      confirmSms += `📋 Please log in to your patient portal to review your appointment details:\n${CONFIG.intakeq.portalUrl}\n\nTo cancel or reschedule (24hr notice required):\n${CONFIG.intakeq.bookingUrl}\n\nQuestions? Call 678-443-4000`;
    }

    await sendSms(sess.callerPhone, confirmSms).catch(() => {});
    const doctorName = sess.practitionerName || CONFIG.intakeq.practitioners.eldred.name;
    await escalateToStaff(sess.callerPhone, 'New appointment booked via Taylor AI', `Patient: ${sess.firstName} ${sess.lastName} | DOB: ${sess.dob || 'not collected'} | Phone: ${sess.collectedPhone || sess.callerPhone} | Address: ${sess.address || 'not collected'} | Service: ${sess.serviceName} | Doctor: ${doctorName} | Time: ${sess.selectedSlot.label} | IntakeQ ID: ${appt.Id} | New patient: ${result.isNew} | Telehealth: ${isTelehealth}`).catch(() => {});
    sendCallSummaryToStaff(sess.callerPhone, `Reason: Appointment booking\nPatient: ${sess.firstName} ${sess.lastName}\nDOB: ${sess.dob || 'not collected'}\nPhone: ${sess.collectedPhone || sess.callerPhone}\nAddress: ${sess.address || 'not collected'}\nService: ${sess.serviceName}\nDoctor: ${doctorName}\nTime: ${sess.selectedSlot.label}\nIntakeQ ID: ${appt.Id}\nTelehealth: ${isTelehealth}\nOutcome: Confirmed${!existingPin ? ', PIN created' : ''}`).catch(() => {});
    const pinMsg = !existingPin ? `I've also created a security PIN for you and included it in your confirmation email — please save it for future calls. ` : '';

    if (requiresForms) {
      say(twiml, `You're all set, ${sess.pronouncedName || sess.firstName}! Your ${isTelehealth ? 'telehealth ' : ''}appointment for ${sess.serviceName} is confirmed for ${sess.selectedSlot.label}. ${pinMsg}Your patient intake forms have been automatically sent to your email via the patient portal — please complete and submit them at least 24 business hours before your appointment. This is very important: if your forms are not submitted at least 24 business hours before your appointment, your appointment will be automatically cancelled and you will need to contact us to reschedule. We are so looking forward to seeing you!`);
    } else {
      say(twiml, `You're all set, ${sess.pronouncedName || sess.firstName}! Your appointment for ${sess.serviceName} is confirmed for ${sess.selectedSlot.label}. I've sent you a confirmation email with all the details, directions, and parking instructions. ${pinMsg}If you ever need to cancel or reschedule, please give us at least 24 hours notice to avoid a cancellation fee. We are so looking forward to seeing you!`);
    }
  } catch (err) {
    console.error('[BOOKING]', err.message);
    const patientEmail = sess.patientRecord?.Email || null;
    if (patientEmail) {
      sendPortalLinkToPatient(patientEmail, `${sess.firstName || ''} ${sess.lastName || ''}`.trim()).catch(() => {});
    }
    escalateToStaff(sess.callerPhone, 'Booking failed — patient needs follow-up', `${sess.firstName || ''} ${sess.lastName || ''} tried to book ${sess.serviceName || ''} at ${sess.selectedSlot?.label || 'unknown'}`).catch(() => {});
    say(twiml, `I'm so sorry — I ran into a little issue completing your booking. I've sent a portal link to your email on file. The patient portal allows you to communicate directly with our doctors, view your invoices, book appointments, and see your prescription history. Please visit Taylor Medical Group dot net and click Patient Portal in the top right corner to complete your booking.`);
  }
  // Mark call as complete to prevent re-triggering booking flow
  sess._callComplete = true;
  // Mark contact info as already confirmed — any subsequent request (refill, letter, etc.) skips re-collection
  sess.contactInfoConfirmed = true;
  // Post-call verification: check IntakeQ 90s after call ends to confirm booking was created
  if (sess._intendedAction === 'booking' || bookingSuccess) {
    const patientName = `${sess.firstName || ''} ${sess.lastName || ''}`.trim();
    setTimeout(() => {
      verifyBookingAfterCall(callSid, sess.callerPhone, patientName, 'booking').catch(() => {});
    }, 90000);
  }
  const g = gather(twiml, '/call-complete-check', { timeout: 6 }); say(g, "Is there anything else I can help you with today?"); twiml.hangup();
  res.type('text/xml').send(twiml.toString());
});

// ═══════════════════════════════════════════════════════════════════════════════
app.post('/call-complete-check', (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase().trim();
  const twiml = new VoiceResponse();
  const hasMore = /yes|yeah|yep|sure|actually|also|one more|another|i have|i do/.test(speech);
  if (hasMore) {
    // Caller has a different question — route to general help, NOT booking flow
    const g = gather(twiml, '/general-help', { input: 'speech', speechTimeout: '3', timeout: 12 });
    say(g, "Of course! What else can I help you with today?");
  } else {
    say(twiml, "Wonderful! Thank you so much for calling Taylor Medical Group. Have a great day!");
    twiml.hangup();
  }
  res.type('text/xml').send(twiml.toString());
});

app.post('/general-help', (req, res) => {
  const speech = (req.body.SpeechResult || '').toLowerCase().trim();
  const callSid = req.body.CallSid;
  const twiml = new VoiceResponse();
  const sess = getSession(callSid);
  // Route to appropriate handler based on what they say, but never re-enter booking flow
  if (/direction|address|location|park/.test(speech)) {
    twiml.redirect('/directions-info');
  } else if (/hour|open|close|schedule/.test(speech)) {
    twiml.redirect('/hours-info');
  } else if (/portal|patient portal|message/.test(speech)) {
    twiml.redirect('/portal-info');
  } else if (/lab|result|test/.test(speech)) {
    twiml.redirect('/lab-results-info');
  } else if (/refill|prescription|medication/.test(speech)) {
    twiml.redirect('/refill-start');
  } else {
    const g = gather(twiml, '/message-collect', { input: 'speech', speechTimeout: '3', timeout: 12 });
    say(g, "Of course! Please go ahead and tell me what you need, and I'll make sure the team gets your message.");
  }
  res.type('text/xml').send(twiml.toString());
});

